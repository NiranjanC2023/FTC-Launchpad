<!DOCTYPE html>

<html lang="en">

<head>

  <meta charset="UTF-8" />

  <title>Find FIRST</title>

  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <meta name="description" content="Connects robotics teams with students seeking to join, fostering collaboration and innovation in robotics education and community engagement." />

  <meta name="robots" content="index, follow" />



  <link rel="preconnect" href="https://fonts.googleapis.com">

  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.3/dist/css/splide.min.css">

  <link rel="stylesheet" href="/assets/css/main.css?v=18">

  <link rel="stylesheet" href="/assets/css/first-start.css?v=8">

</head>

<body class="home-page">

  <header></header>



  <% const benefits = [

    { title: "Hands-On Engineering", description: "Design, build, and program real robots using industry-standard tools and techniques." },

    { title: "Team Collaboration", description: "Work alongside peers who share your passion for technology and problem-solving." },

    { title: "Compete Nationally", description: "Represent your team at regional, state, and national competitions with thousands of students." },

    { title: "Creative Problem Solving", description: "Face new engineering challenges each season that push your creativity and critical thinking." },

    { title: "Scholarship Opportunities", description: "Hundreds of scholarships are awarded each year specifically to robotics competitors." },

    { title: "Industry Mentorship", description: "Get mentored by engineers and professionals from leading tech and manufacturing companies." }

  ]; %>



  <% const studentSteps = [

    { number: "01", title: "Create your profile", description: "Share your interests, grade level, skills, and location so teams can find the right fit." },

    { number: "02", title: "Browse and discover teams", description: "Filter by location, competition league, team culture, and open roles to narrow your search." },

    { number: "03", title: "Apply or reach out", description: "Send a message directly to team coaches and captains to introduce yourself and ask questions." },

    { number: "04", title: "Join and compete", description: "Get onboarded, start contributing, and compete in your first season." }

  ]; %>



  <% const teamSteps = [

    { number: "01", title: "Register your team", description: "Add your league, location, open roles, and the kind of students your team needs." },

    { number: "02", title: "Review applicants", description: "Browse student profiles that match your needs and have already shown interest." },

    { number: "03", title: "Invite students", description: "Reach out to promising candidates and invite them to a tryout or info session." },

    { number: "04", title: "Build your roster", description: "Fill open spots with motivated students who are ready to contribute." }

  ]; %>



  <% const defaultFeaturedTeams = [

    { number: "1114", name: "Simbotics", logo: "SB", location: "St. Catharines, ON", league: "FRC", members: 35, championships: 3, openRoles: ["Mechanical", "Programming"], color: "#e74c3c", description: "One of FRC's most celebrated teams, known for consistent excellence in design and strategy." },

    { number: "254", name: "Cheesy Poofs", logo: "CP", location: "San Jose, CA", league: "FRC", members: 28, championships: 4, openRoles: ["Software", "CAD", "Business"], color: "#f39c12", description: "A powerhouse team with deep ties to Silicon Valley's tech community and strong mentorship culture." },

    { number: "3647", name: "Millennium Falcons", logo: "MF", location: "Austin, TX", league: "FTC", members: 12, championships: 1, openRoles: ["Mechanical", "Drive Team", "Media"], color: "#3498db", description: "A growing FTC team built around inclusivity and hands-on learning for students of all backgrounds." }

  ]; %>



  <main class="home-main">

    <section class="home-hero">

      <div class="container home-hero-grid">

        <div class="home-hero-copy">

          <div class="hero-pill">Teams looking for students!</div>

          <h1>Find FIRST<br><span>Find your robotics team!</span></h1>

          <p class="hero-description">
            Find FIRST helps students discover robotics teams and helps teams recruit motivated members, all in one place.
            Search by location, compare openings, and reach out when you find the right fit.

          </p>



          <form class="home-search" action="/teams-nearby" method="GET">

            <div class="home-search-field">

              <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>

              <input type="search" name="q" placeholder="Search by city, state, or team name..." aria-label="Search teams" />

            </div>

            <button type="submit" class="btn btn-primary home-search-btn">Search Teams</button>

          </form>



          <div class="hero-actions">

            <a href="/teams-nearby" class="btn btn-primary hero-primary-link">Browse Teams <i class="fa-solid fa-arrow-right"></i></a>

            <a href="/team-register" class="btn btn-secondary hero-secondary-link">Register Your Team</a>

          </div>



          <div class="home-hero-mini" aria-label="How Find FIRST works">
            <div class="home-mini-card">
              <span>1</span>
              <strong>Search teams</strong>
              <p>Find nearby FTC teams by city, league, or role.</p>
            </div>
            <div class="home-mini-card">
              <span>2</span>
              <strong>Compare openings</strong>
              <p>See who is recruiting, what they need, and when they meet.</p>
            </div>
            <div class="home-mini-card">
              <span>3</span>
              <strong>Join or register</strong>
              <p>Students can apply, and teams can list openings fast.</p>
            </div>
          </div>

        </div>



        <div class="home-hero-visual">

          <div class="hero-image-card">

            <div class="splide home-carousel" id="fs-carousel-home" role="region" aria-label="Robotics team carousel">

              <div class="splide__track">

                <ul class="splide__list">

                  <% if (typeof carouselImages !== 'undefined' && carouselImages.length) { %>

                    <% carouselImages.forEach(function(item, idx){ %>

                      <li class="splide__slide">

                        <img src="<%= item.src %>" <%= item.srcset ? ('srcset="' + item.srcset + '"') : '' %> alt="Robotics team image <%= idx + 1 %>">

                      </li>

                    <% }); %>

                  <% } else { %>

                    <li class="splide__slide"><img src="/assets/img/carousel/54353383874_f79a24fab7_c%20(2).jpg" alt="Robotics team image 1"></li>

                    <li class="splide__slide"><img src="/assets/img/carousel/IMG_1014_frame_0_01_2f.jpeg" alt="Robotics team image 2"></li>

                    <li class="splide__slide"><img src="/assets/img/carousel/WhatsApp%20Image%202026-01-17%20at%201.09.15%20PM%20(3).jpeg" alt="Robotics team image 3"></li>

                    <li class="splide__slide"><img src="/assets/img/carousel/Untitled%20design.png" alt="Robotics team image 4"></li>

                  <% } %>

                </ul>

              </div>

            </div>

          </div>



          <div class="floating-card floating-card-top">

            <span>FIRST teams</span>

            <strong>79,000</strong>

            <p>active FIRST teams</p>

          </div>



          <div class="floating-card floating-card-bottom">

            <span>Youth participants</span>

            <strong>853,000</strong>

            <p>youth participants</p>

          </div>

        </div>

      </div>



      <div class="home-wave">
        <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0 60L1440 60L1440 20C1200 60 960 0 720 20C480 40 240 0 0 20L0 60Z" fill="white" />
        </svg>
      </div>

    </section>
    <div class="home-surface">
    <section class="home-why">

      <div class="container home-why-grid">

        <div class="home-why-image">

          <img src="/assets/img/why-join-first.png" alt="Students collaborating on an engineering project">

        </div>



        <div class="home-why-copy">

          <p class="section-kicker">Why Robotics?</p>

          <h3>Why join FIRST</h3>

          <p class="lead">FIRST builds science, technology, engineering, and math skills through teamwork, mentoring, and hands-on challenges.</p>

          <ul class="why-join-list">
            <li>Learn practical STEM skills in a fun environment</li>
            <li>Get mentorship from adults and college students</li>
            <li>Develop teamwork, project planning, and communication</li>
            <li>Compete at events and showcase your innovations</li>
          </ul>

        </div>

      </div>

    </section>



    <section id="how-it-works" class="home-how">

      <div class="container">

        <div class="section-heading">

          <p class="section-kicker">How It Works</p>

          <h2>Simple for students. Simple for teams.</h2>

          <p>We built the platform so the hard part is building robots, not finding each other.</p>

        </div>



        <div class="home-how-grid">

          <div class="home-path-card home-path-card-students">

            <div class="path-badge-row path-badge-row-students">
              <span class="pill">For Students</span>
            </div>

            <h3>Find your team in 4 steps</h3>

            <p class="path-intro">Start with a profile, then narrow your search, reach out, and join a team that matches your goals.</p>

            <div class="steps-list">

              <% studentSteps.forEach(function(step, index){ %>

                <div class="step-row">

                  <div class="step-marker">

                    <span><%= step.number %></span>

                  </div>

                  <div class="step-copy">

                    <h4><%= step.title %></h4>

                    <p><%= step.description %></p>

                  </div>

                </div>

              <% }); %>

            </div>

            <a href="/teams-nearby" class="path-button">Find a Team &rarr;</a>

          </div>



          <div class="home-path-card home-path-card-teams" id="for-teams">

            <div class="path-badge-row path-badge-row-teams">
              <span class="pill pill-alt">For Teams</span>
            </div>

            <h3>Recruit top talent in 4 steps</h3>

            <p class="path-intro path-intro-alt">Register your team, review applicants, invite students, and build a roster that fits your needs.</p>

            <div class="steps-list">

              <% teamSteps.forEach(function(step, index){ %>

                <div class="step-row">

                  <div class="step-marker step-marker-alt">

                    <span><%= step.number %></span>

                  </div>

                  <div class="step-copy">

                    <h4><%= step.title %></h4>

                    <p><%= step.description %></p>

                  </div>

                </div>

              <% }); %>

            </div>

            <a href="/team-register" class="path-button path-button-alt">Register Your Team &rarr;</a>

          </div>

        </div>

      </div>

    </section>



    <section id="teams" class="home-teams">

      <div class="container">

        <div class="section-heading section-heading-left">

          <div>

            <p class="section-kicker">Featured Teams</p>

            <h2>Teams actively recruiting</h2>


          </div>

          <a href="/teams-nearby" class="section-link">View all teams <i class="fa-solid fa-chevron-right" aria-hidden="true"></i></a>

        </div>



        <div class="home-teams-grid" id="homeFeaturedTeams">

          <% const featuredTeams = typeof homeFeaturedTeams !== 'undefined' && Array.isArray(homeFeaturedTeams) && homeFeaturedTeams.length ? homeFeaturedTeams : defaultFeaturedTeams; %>

          <% featuredTeams.forEach(function(team, index){ %>

            <article class="team-card" style="--team-accent: <%= team.color %>; --team-card-index: <%= index %>">

              <div class="team-card-bar" style="background-color: <%= team.color %>"></div>

              <div class="team-card-body">

                <div class="team-card-top">

                  <div class="team-card-brand">
                    <div class="team-logo-badge" style="border-color: <%= team.color %>33; background-color: <%= team.color %>12; color: <%= team.color %>"><%= team.logo || team.name.split(/\s+/).slice(0,2).map(function(word){ return word.charAt(0); }).join('') %></div>
                    <div class="team-number" style="border-color: <%= team.color %>33; background-color: <%= team.color %>15; color: <%= team.color %>">#<%= team.number %></div>
                  </div>

                  <span class="league-pill"><%= team.league %></span>

                </div>

                <h3><%= team.name %></h3>

                <p class="team-location"><i class="fa-solid fa-map-pin" aria-hidden="true"></i> <%= team.location %></p>

                <p class="team-description"><%= team.description %></p>

                <% const teamProgram = String(team.program || team.league || '').toUpperCase(); %>
                <% const teamNumber = team.teamNumber || team.number || ''; %>
                <% const awardHistory = Array.isArray(team.awardHistory) ? team.awardHistory : []; %>
                <% const advancementHistory = Array.isArray(team.advancementHistory) ? team.advancementHistory : []; %>
                <% const scoutingPageUrl = teamNumber ? (teamProgram === 'FRC' ? 'https://www.thebluealliance.com/team/' + teamNumber : teamProgram === 'FTC' ? 'https://ftcscout.org/teams/' + teamNumber : null) : null; %>
                <% if (awardHistory.length || advancementHistory.length || scoutingPageUrl) { %>
                  <div class="team-card-history">
                    <% if (awardHistory.length) { %>
                      <p class="team-card-history-label">Awards</p>
                      <p class="team-card-history-text"><%= awardHistory.slice(0, 2).join(', ') %><%= awardHistory.length > 2 ? ' +' + (awardHistory.length - 2) + ' more' : '' %></p>
                    <% } %>
                    <% if (advancementHistory.length) { %>
                      <p class="team-card-history-label">Advancement</p>
                      <p class="team-card-history-text"><%= advancementHistory.slice(0, 2).join(', ') %><%= advancementHistory.length > 2 ? ' +' + (advancementHistory.length - 2) + ' more' : '' %></p>
                    <% } %>
                    <% if (scoutingPageUrl) { %>
                      <a class="team-card-history-link" href="<%= scoutingPageUrl %>" target="_blank" rel="noopener noreferrer">
                        <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                        <%= teamProgram === 'FRC' ? 'See on The Blue Alliance' : 'See on FTC Scout' %>
                      </a>
                    <% } %>
                  </div>
                <% } %>

                <div class="team-meta">

                  <span><span class="team-meta-icon" aria-hidden="true"><i class="fa-solid fa-users" aria-hidden="true"></i></span> <%= team.members %> members</span>

                  <span><span class="team-meta-icon" aria-hidden="true"><i class="fa-solid fa-trophy" aria-hidden="true"></i></span> <%= team.championships %> championship<%= team.championships !== 1 ? 's' : '' %></span>

                </div>

                <div class="team-roles">

                  <% const openRoles = Array.isArray(team.openRoles) ? team.openRoles : []; %>
                  <% openRoles.forEach(function(role){ %>

                    <span><%= role %></span>

                  <% }); %>

                </div>

                <button type="button" class="team-button">View Team & Apply</button>

              </div>

            </article>

          <% }); %>

        </div>

      </div>

    </section>
    <section class="home-cta">

      <div class="container">

        <div class="home-cta-card">

          <div class="home-cta-overlay"></div>

          <div class="home-cta-content">

            <h2>Your robotics journey starts with finding the right team.</h2>

            <p>Whether you're a student ready to build something incredible, or a team looking for your next star recruit &mdash; Find FIRST is where it begins.</p>

            <div class="hero-actions hero-actions-center">

              <a href="/teams-nearby" class="btn btn-primary hero-primary-link">Find a Team <i class="fa-solid fa-arrow-right"></i></a>

              <a href="/team-register" class="btn btn-secondary hero-secondary-link">Register Your Team</a>

            </div>

            <span class="cta-note">Free to join. No experience required. Open to all K-12 students.</span>

          </div>

        </div>

      </div>

    </section>

    </div>


  </main>



  <script src="/assets/js/main.js?v=9"></script>

  <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.3/dist/js/splide.min.js"></script>

  <script src="/assets/js/first-start.js?v=8"></script>

</body>

</html>







