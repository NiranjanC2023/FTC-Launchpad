<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Google Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
  <link rel="stylesheet" href="/assets/css/first-start.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.3/dist/css/splide.min.css">
</head>
<body class="home-page">
  <header>
    <div class="creator-badge">Created By FTC 25690</div>
  </header>

  <main>
    <!-- Legacy homepage sections removed. FIRST Start promotional section is shown below. -->

    <!-- FIRST Start promotional section (from FIRST Start page) -->
    <section class="first-hero">
      <div class="container">
        <div class="first-start-header">
          <h1 class="fs-title">FIRST Start</h1>
          <p class="fs-subtext">Connecting students to teams — learn practical STEM skills, get mentorship, and compete together.</p>
        </div>
        <div class="first-hero-inner">
          <div class="splide" id="fs-carousel-home" role="region" aria-label="FIRST image carousel">
            <div class="splide__track">
              <ul class="splide__list">
                <% if (typeof carouselImages !== 'undefined' && carouselImages.length) { %>
                  <% carouselImages.forEach(function(item, idx){ %>
                    <li class="splide__slide">
                      <img src="<%= item.src %>" <%= item.srcset ? ('srcset="' + item.srcset + '"') : '' %> alt="FIRST image <%= idx+1 %>">
                    </li>
                  <% }); %>
                <% } else { %>
                  <li class="splide__slide"><img src="/assets/img/Explaining%20FLL.png" alt="FIRST image 1"></li>
                  <li class="splide__slide"><img src="/assets/img/FIRST%20Fare.png" alt="FIRST image 2"></li>
                  <li class="splide__slide"><img src="/assets/img/FIRST%20Team.png" alt="FIRST image 3"></li>
                  <li class="splide__slide"><img src="/assets/img/FLL%20Robot.png" alt="FIRST image 4"></li>
                <% } %>
              </ul>
            </div>
          </div>

          <div class="why-join">
            <h3>Why join FIRST</h3>
            <p class="lead">FIRST builds science, technology, engineering, and math skills through teamwork, mentoring, and hands-on challenges.</p>
            <ul>
              <li>Learn practical STEM skills in a fun environment</li>
              <li>Get mentorship from adults and college students</li>
              <li>Develop teamwork, project planning, and communication</li>
              <li>Compete at events and showcase your innovations</li>
            </ul>
            
          </div>
        </div>
      </div>
    </section>

    <section class="connect-graphic">
      <div class="container">
        <h3>Connecting students to teams</h3>
        <p class="connect-subtitle">A simple path to getting involved with FIRST.</p>
        <div class="connect-stage" aria-label="Connecting students to teams diagram">
          <a class="connect-card connect-card-join" href="/teams-nearby">
            Join a team
            <span>For students who want to get started</span>
          </a>

          <div class="connect-center" aria-hidden="true">
            <div class="connect-node">
              <div class="connect-people">
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>
          </div>

          <a class="connect-card connect-card-register" href="/team-register">
            Register a team
            <span>For mentors, coaches, and organizers</span>
          </a>

          <span class="connect-path connect-path-left" aria-hidden="true"></span>
          <span class="connect-path connect-path-right" aria-hidden="true"></span>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container">
        <p><strong>Built by Evergreen Tech-a-Trons</strong> — a student engineering team focused on accessibility
           and outreach for FIRST programs. To contribute, report an issue, or request a feature, please visit
           the contact page or reach out to the Evergreen Tech-a-Trons via the site.</p>
        <p class="small">© Evergreen Tech-a-Trons — All rights reserved.</p>
      </div>
    </footer>
  </main>

  <script src="/assets/js/main.js?v=8"></script>
  <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.3/dist/js/splide.min.js"></script>
  <script src="/assets/js/first-start.js"></script>
</body>
</html>
