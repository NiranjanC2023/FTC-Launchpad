<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>My Account - FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .account-hero { background: var(--surface); border-bottom: 1px solid var(--border-color); padding: 40px 0; margin-bottom: 40px; }
    .account-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
    .account-card { background: var(--surface); padding: 28px; border-radius: var(--radius-lg); border: 1px solid var(--border-color); text-align: left; }
    .account-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 18px; }
    .account-pill { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: 999px; background: rgba(26, 163, 74, 0.1); color: var(--accent-primary); font-weight: 700; margin-bottom: 12px; }
    .account-list { list-style: none; padding: 0; margin: 0; }
    .account-list li { padding: 8px 0; border-bottom: 1px solid var(--border-color); }
    .account-list li:last-child { border-bottom: 0; }
    .account-photo {
      width: 112px;
      height: 112px;
      border-radius: 50%;
      object-fit: cover;
      display: block;
      border: 4px solid rgba(26, 163, 74, 0.18);
      margin-bottom: 14px;
      background: #eef6f0;
    }
    .account-photo-placeholder {
      width: 112px;
      height: 112px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #dff6e8, #8be0ae);
      color: #0f5b34;
      font-size: 2.1rem;
      font-weight: 800;
      border: 4px solid rgba(26, 163, 74, 0.18);
      margin-bottom: 14px;
    }
    .photo-control {
      position: relative;
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .photo-change {
      border: 0;
      background: transparent;
      color: var(--accent-primary);
      font-weight: 800;
      padding: 0;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.18s ease;
    }
    .photo-control:hover .photo-change,
    .photo-control:focus-within .photo-change {
      opacity: 1;
    }
    .photo-menu {
      width: 100%;
      display: none;
      padding: 12px;
      border-radius: 14px;
      border: 1px solid var(--border-color);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: var(--shadow-sm);
    }
    .photo-control:hover .photo-menu,
    .photo-control:focus-within .photo-menu {
      display: grid;
      gap: 8px;
    }
    @media (hover: none) {
      .photo-menu {
        display: grid;
        gap: 8px;
      }
    }
    .photo-menu .form-control {
      min-height: 40px;
      padding: 8px 10px;
    }
    .account-form {
      margin-top: 16px;
      display: grid;
      gap: 10px;
    }
  </style>
</head>
<body class="dashboard-page">
  <header></header>

  <section class="account-hero">
    <div class="container">
      <h1>My Account</h1>
      <p class="text-muted">Manage your profile, settings, and sign-in details from one place.</p>
    </div>
  </section>

  <main class="container">
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div class="account-grid">
      <div class="account-card">
        <div class="account-pill"><i class="fa-solid fa-user"></i> Profile</div>
        <div class="photo-control">
          <% if (user && user.profilePicture) { %>
            <img class="account-photo" id="accountPhotoPreview" src="<%= user.profilePicture %>" alt="Profile picture">
          <% } else { %>
            <div class="account-photo-placeholder" id="accountPhotoPreview"><%= user && user.name ? user.name.split(/\s+/).filter(Boolean).slice(0,2).map(part => part[0].toUpperCase()).join('') : 'U' %></div>
          <% } %>
          <button type="button" class="photo-change" aria-controls="photoMenu">Change</button>
          <small class="text-muted">Hover to change</small>
        </div>
        <h2 style="margin-top: 0;"><%= user ? user.name : 'Account' %></h2>
        <p class="text-muted"><%= user ? user.email : '' %></p>
        <ul class="account-list">
          <li><strong>Age:</strong> <%= user && user.age ? user.age : '—' %></li>
          <li><strong>Phone:</strong> <%= user && user.phone ? user.phone : '—' %></li>
          <li><strong>Interests:</strong> <%= studentProfile && studentProfile.interests ? studentProfile.interests : (user && user.interests ? user.interests : '—') %></li>
          <li><strong>Experience:</strong> <%= studentProfile && studentProfile.experience ? studentProfile.experience : (user && user.experience ? user.experience : '—') %></li>
        </ul>
        <div class="account-actions">
          <a href="/join-form" class="btn btn-primary">Edit signup info</a>
          <a href="/logout" class="btn btn-secondary">Sign out</a>
        </div>
        <form class="account-form" method="POST" action="/account">
          <input type="hidden" id="profilePicture" name="profilePicture" value="<%= user && user.profilePicture ? user.profilePicture : '' %>">
          <div class="photo-menu" id="photoMenu">
            <label class="form-label" for="profilePictureFile">Upload photo</label>
            <input class="form-control" type="file" id="profilePictureFile" accept="image/*">
            <small class="text-muted">Choose an image and save it to your account.</small>
          </div>
          <button class="btn btn-primary" type="submit">Save picture</button>
        </form>
      </div>

      <div class="account-card">
        <div class="account-pill"><i class="fa-solid fa-gear"></i> Settings</div>
        <h2 style="margin-top: 0;">Quick settings</h2>
        <p class="text-muted">Use the links below to jump to the parts of the site tied to your account.</p>
        <ul class="account-list">
          <li><a href="/join-form">Update profile details</a></li>
          <li><a href="/my-applications">View applications</a></li>
          <% if (team) { %>
            <li><a href="/manage-team">Manage your team</a></li>
            <li><a href="/my-team">My team page</a></li>
          <% } else { %>
            <li><a href="/teams-nearby">Find nearby teams</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </main>

  <script src="/assets/js/main.js"></script>
  <script>
    (() => {
      const fileInput = document.getElementById('profilePictureFile');
      const hiddenInput = document.getElementById('profilePicture');
      const photoMenu = document.getElementById('photoMenu');
      const preview = document.getElementById('accountPhotoPreview');
      const changeButton = document.querySelector('.photo-change');
      if (!fileInput || !hiddenInput) return;

      if (changeButton) {
        changeButton.addEventListener('click', () => fileInput.click());
      }

      fileInput.addEventListener('change', () => {
        const file = fileInput.files && fileInput.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = () => {
          const result = String(reader.result || '');
          hiddenInput.value = result;
          if (preview) {
            if (preview.tagName === 'IMG') {
              preview.src = result;
            } else {
              const img = document.createElement('img');
              img.className = 'account-photo';
              img.id = 'accountPhotoPreview';
              img.src = result;
              img.alt = 'Profile picture';
              preview.replaceWith(img);
            }
          }
        };
        reader.readAsDataURL(file);
      });
    })();
  </script>
</body>
</html>
