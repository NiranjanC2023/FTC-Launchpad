<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Reset Password - FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css?v=23">
</head>
<body class="auth-page">
  <header></header>

  <main>
    <div class="container">
      <a href="/login" class="btn btn-secondary back-button">&larr; Back to Log In</a>
      <h1>Reset Password</h1>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert" style="background:#e9f8ef;border-color:#b8edcb;color:#0f5b34;"><%= success %></div>
      <% } %>

      <% if (token) { %>
        <p class="subtitle">Choose a new password for your account.</p>
        <form method="POST" action="/reset-password/<%= token %>" class="login-form" style="max-width: 520px; margin: 0 auto;">
          <div class="mb-3">
            <label class="form-label" for="newPassword">New password</label>
            <input id="newPassword" name="password" type="password" class="form-control" required minlength="8" />
          </div>
          <div class="mb-3">
            <label class="form-label" for="confirmPassword">Confirm password</label>
            <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" required minlength="8" />
          </div>
          <button class="btn btn-primary" type="submit">Update password</button>
        </form>
      <% } else if (!success) { %>
        <p class="subtitle">Use the link from your email to open this page.</p>
      <% } %>
    </div>
  </main>

  <script src="/assets/js/main.js?v=8"></script>
</body>
</html>
