<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Forgot Email or Password - FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css?v=23">
</head>
<body class="auth-page">
  <header></header>

  <main>
    <div class="container">
      <a href="/login" class="btn btn-secondary back-button">&larr; Back to Log In</a>
      <h1>Forgot email or password?</h1>
      <p class="subtitle">Enter the email address on your account and we’ll send a password reset link if an account exists.</p>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert" style="background:#e9f8ef;border-color:#b8edcb;color:#0f5b34;"><%= success %></div>
      <% } %>

      <form method="POST" action="/forgot-password" class="login-form" style="max-width: 520px; margin: 0 auto;">
        <div class="mb-3">
          <label class="form-label" for="forgotEmail">Email</label>
          <input id="forgotEmail" name="email" type="email" class="form-control" value="<%= email || '' %>" required />
        </div>
        <button class="btn btn-primary" type="submit">Send reset link</button>
      </form>

      <p style="margin-top:14px; color: var(--text-secondary);">
        If you are not sure which email you used, contact <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>.
      </p>
    </div>
  </main>

  <script src="/assets/js/main.js?v=8"></script>
</body>
</html>
