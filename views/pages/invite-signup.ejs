<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Accept Manager Invitation</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
</head>
<body class="auth-page">
  <header></header>

  <main>
    <div class="container">
      <a href="/" class="btn btn-secondary back-button">← Back Home</a>
      <h1>Manager Invitation</h1>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } else { %>
        <div class="alert alert-info">
          Welcome! You have been invited to manage <strong><%= teamName %></strong>.
        </div>
      <% } %>

      <p>Sign in or create an account using <strong><%= email %></strong> to accept your manager invitation.</p>
      <div style="display: grid; gap: 18px; margin-top: 22px;">
        <a href="/login?inviteToken=<%= token %>" class="btn btn-primary">Log in</a>
        <a href="/signup/manager?inviteToken=<%= token %>" class="btn btn-secondary">Sign up as manager</a>
      </div>
    </div>
  </main>

  <script src="/assets/js/main.js?v=8"></script>
</body>
</html>