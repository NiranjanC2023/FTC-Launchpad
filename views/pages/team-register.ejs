<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Register Team - FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
</head>
<body>
  <header>
    
  </header>

  <main>
    <div class="container">
      <a href="/" class="btn btn-secondary back-button">&larr; Back Home</a>
      <h1>Register Your Team</h1>
      <p class="subtitle">Verified FIRST teams can choose whether they appear for students looking nearby.</p>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>

      <form method="POST" action="/team-register" class="form-grid">
        <label for="program">FIRST program</label>
        <select id="program" name="program" required>
          <% const selectedProgram = values.program || 'FTC'; %>
          <option value="FTC" <%= selectedProgram === 'FTC' ? 'selected' : '' %>>FIRST Tech Challenge</option>
          <option value="FRC" <%= selectedProgram === 'FRC' ? 'selected' : '' %>>FIRST Robotics Competition</option>
          <option value="FLL Challenge" <%= selectedProgram === 'FLL Challenge' ? 'selected' : '' %>>FIRST LEGO League Challenge</option>
          <option value="FLL Explore" <%= selectedProgram === 'FLL Explore' ? 'selected' : '' %>>FIRST LEGO League Explore</option>
        </select>

        <label for="teamNumber">Team number</label>
        <input id="teamNumber" name="teamNumber" type="number" min="1" required value="<%= values.teamNumber || '' %>" />

        <label for="name">Team name</label>
        <input id="name" name="name" required value="<%= values.name || '' %>" />

        <label for="contact">Contact email</label>
        <input id="contact" name="contact" type="email" required value="<%= values.contact || '' %>" />

        <label for="address">Address</label>
        <input id="address" name="address" required placeholder="Street address or meeting location" value="<%= values.address || '' %>" />

        <label for="city">City</label>
        <input id="city" name="city" required value="<%= values.city || '' %>" />

        <label for="state">State</label>
        <input id="state" name="state" value="<%= values.state || '' %>" />

        <label for="country">Country</label>
        <select id="country" name="country" required>
          <% const selectedCountry = values.country || 'USA'; %>
          <option value="USA" <%= selectedCountry === 'USA' ? 'selected' : '' %>>United States</option>
          <option value="Canada" <%= selectedCountry === 'Canada' ? 'selected' : '' %>>Canada</option>
          <option value="Mexico" <%= selectedCountry === 'Mexico' ? 'selected' : '' %>>Mexico</option>
          <option value="Australia" <%= selectedCountry === 'Australia' ? 'selected' : '' %>>Australia</option>
          <option value="United Kingdom" <%= selectedCountry === 'United Kingdom' ? 'selected' : '' %>>United Kingdom</option>
          <option value="Other" <%= selectedCountry === 'Other' ? 'selected' : '' %>>Other</option>
        </select>

        <label for="notes">Recruiting info</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Meeting days, grades accepted, application link, or what students should include."><%= values.notes || '' %></textarea>

        <span></span>
        <label class="checkbox-row">
          <input type="checkbox" name="recruiting" <%= values.recruiting === undefined || values.recruiting === 'on' ? 'checked' : '' %> />
          <span>Show this team as recruiting</span>
        </label>

        <span></span>
        <button class="btn btn-primary" type="submit">Verify and Save Team</button>
      </form>
    </div>
  </main>

  <script src="/assets/js/main.js?v=8"></script>
</body>
</html>
