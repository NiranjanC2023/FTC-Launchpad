<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Register Team - FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
</head>
<body>
  <header>
    
  </header>

  <main>
    <div class="container">
      <a href="/" class="btn btn-secondary back-button">&larr; Back Home</a>
      <h1>Register Your Team</h1>
      <p class="subtitle">Verified FIRST teams can choose whether they appear for students looking nearby.</p>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>

      <form method="POST" action="/team-register" class="form-grid">
        <% const selectedMode = values.registrationMode || 'existing'; %>
        <% const selectedProgram = values.program || 'FTC'; %>
        <% const showRegistrationExtras = selectedMode !== 'new' && (selectedProgram === 'FLL Challenge' || selectedProgram === 'FLL Explore'); %>
        <% const usesOfficialApiLocation = selectedMode !== 'new' && (selectedProgram === 'FTC' || selectedProgram === 'FRC'); %>

        <div class="registration-choice form-grid-full">
          <p class="registration-choice-question">Is this a new team or an existing registered team?</p>
          <div class="registration-choice-options">
            <label class="choice-pill">
              <input type="radio" name="registrationMode" value="existing" <%= selectedMode === 'existing' ? 'checked' : '' %> />
              <span>Existing team</span>
            </label>
            <label class="choice-pill">
              <input type="radio" name="registrationMode" value="new" <%= selectedMode === 'new' ? 'checked' : '' %> />
              <span>New team</span>
            </label>
          </div>
          <p class="registration-choice-note">Existing teams will be verified and can use lookup-based details. New teams skip verification and show up as new teams on the map.</p>
        </div>

        <label for="program">FIRST program</label>
        <select id="program" name="program" required>
          <option value="FTC" <%= selectedProgram === 'FTC' ? 'selected' : '' %>>FIRST Tech Challenge</option>
          <option value="FRC" <%= selectedProgram === 'FRC' ? 'selected' : '' %>>FIRST Robotics Competition</option>
          <option value="FLL Challenge" <%= selectedProgram === 'FLL Challenge' ? 'selected' : '' %>>FIRST LEGO League Challenge</option>
          <option value="FLL Explore" <%= selectedProgram === 'FLL Explore' ? 'selected' : '' %>>FIRST LEGO League Explore</option>
        </select>

        <div class="registration-field-inline form-grid-full <%= selectedMode === 'new' ? 'registration-hidden' : '' %>" data-registration-field="teamNumber">
          <label for="teamNumber">Team number</label>
          <input id="teamNumber" name="teamNumber" type="number" min="1" <%= selectedMode === 'new' ? '' : 'required' %> value="<%= values.teamNumber || '' %>" />
        </div>

        <label for="name">Team name</label>
        <input id="name" name="name" required value="<%= values.name || '' %>" />

        <label for="contact">Contact email</label>
        <input id="contact" name="contact" type="email" required value="<%= values.contact || '' %>" />

        <label for="address">Team address</label>
        <input id="address" name="address" placeholder="Street or meeting address" <%= usesOfficialApiLocation ? 'required' : '' %> value="<%= values.address || '' %>" />
        <small class="text-muted form-note form-grid-full" data-location-note>For privacy, the exact team address is hidden. Students see a 1,000-meter circle centered on an offset map location.</small>

        <label for="city" class="<%= usesOfficialApiLocation ? 'registration-hidden' : '' %>" data-detailed-location-field>City</label>
        <input id="city" name="city" class="<%= usesOfficialApiLocation ? 'registration-hidden' : '' %>" data-detailed-location-field <%= usesOfficialApiLocation ? 'disabled' : '' %> value="<%= values.city || '' %>" />

        <label for="state" class="<%= usesOfficialApiLocation ? 'registration-hidden' : '' %>" data-detailed-location-field>State</label>
        <input id="state" name="state" class="<%= usesOfficialApiLocation ? 'registration-hidden' : '' %>" data-detailed-location-field <%= usesOfficialApiLocation ? 'disabled' : '' %> value="<%= values.state || '' %>" />

        <label for="country" class="<%= usesOfficialApiLocation ? 'registration-hidden' : '' %>" data-detailed-location-field>Country</label>
        <select id="country" name="country" class="<%= usesOfficialApiLocation ? 'registration-hidden' : '' %>" data-detailed-location-field <%= usesOfficialApiLocation ? 'disabled' : 'required' %>>
          <% const selectedCountry = values.country || 'USA'; %>
          <option value="USA" <%= selectedCountry === 'USA' ? 'selected' : '' %>>United States</option>
          <option value="Canada" <%= selectedCountry === 'Canada' ? 'selected' : '' %>>Canada</option>
          <option value="Mexico" <%= selectedCountry === 'Mexico' ? 'selected' : '' %>>Mexico</option>
          <option value="Australia" <%= selectedCountry === 'Australia' ? 'selected' : '' %>>Australia</option>
          <option value="United Kingdom" <%= selectedCountry === 'United Kingdom' ? 'selected' : '' %>>United Kingdom</option>
          <option value="Other" <%= selectedCountry === 'Other' ? 'selected' : '' %>>Other</option>
        </select>

        <label for="notes">Recruiting info</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Meeting days, grades accepted, application link, or what students should include."><%= values.notes || '' %></textarea>

        <div class="registration-extra-grid form-grid-full <%= showRegistrationExtras ? '' : 'registration-hidden' %>" data-registration-extras>
          <label for="awards">Awards</label>
          <input id="awards" name="awards" placeholder="Optional: Inspire Award, Control Award, regional finalist, etc." value="<%= values.awards || '' %>" />

          <label for="yearsInProgram">Years in program</label>
          <input id="yearsInProgram" name="yearsInProgram" type="number" min="0" step="1" placeholder="Optional: 1, 3, 6..." value="<%= values.yearsInProgram || '' %>" />
          <small class="text-muted form-note form-grid-full">FTC teams can auto-fill awards and years in program from FTC Scout, and FRC teams can do the same through Blue Alliance when verified.</small>
        </div>

        <span></span>
        <label class="checkbox-row">
          <input type="checkbox" name="recruiting" <%= values.recruiting === undefined || values.recruiting === 'on' ? 'checked' : '' %> />
          <span>Show this team as recruiting</span>
        </label>

        <span></span>
        <button class="btn btn-primary" type="submit">Verify and Save Team</button>
      </form>
    </div>
  </main>

  <script src="/assets/js/main.js?v=9"></script>
  <script>
    (function() {
      const form = document.querySelector('.form-grid');
      if (!form) return;
      const modeInputs = Array.from(form.querySelectorAll('input[name="registrationMode"]'));
      const teamNumberField = form.querySelector('[data-registration-field="teamNumber"]');
      const extrasField = form.querySelector('[data-registration-extras]');
      const teamNumberInput = form.querySelector('#teamNumber');
      const awardsInput = form.querySelector('#awards');
      const yearsInput = form.querySelector('#yearsInProgram');
      const extraInputs = [awardsInput, yearsInput].filter(Boolean);
      const addressInput = form.querySelector('#address');
      const countryInput = form.querySelector('#country');
      const detailedLocationFields = Array.from(form.querySelectorAll('[data-detailed-location-field]'));
      const detailedLocationInputs = detailedLocationFields.filter(field => field.matches('input, select'));
      const locationNote = form.querySelector('[data-location-note]');

      function syncMode() {
        const selected = modeInputs.find(input => input.checked);
        const isNew = selected && selected.value === 'new';
        const programValue = String(form.querySelector('#program')?.value || '').trim();
        const showExtras = !isNew && (programValue === 'FLL Challenge' || programValue === 'FLL Explore');
        const usesApiLocation = !isNew && (programValue === 'FTC' || programValue === 'FRC');

        if (teamNumberField) teamNumberField.classList.toggle('registration-hidden', isNew);
        if (teamNumberInput) {
          teamNumberInput.required = !isNew;
          teamNumberInput.disabled = isNew;
          if (isNew) teamNumberInput.value = '';
        }

        if (extrasField) extrasField.classList.toggle('registration-hidden', !showExtras);
        extraInputs.forEach((input) => {
          input.disabled = !showExtras;
        });

        detailedLocationFields.forEach((field) => {
          field.classList.toggle('registration-hidden', usesApiLocation);
        });
        detailedLocationInputs.forEach((input) => {
          input.disabled = usesApiLocation;
        });
        if (addressInput) addressInput.required = usesApiLocation;
        if (countryInput) countryInput.required = !usesApiLocation;
        if (locationNote) {
          locationNote.textContent = 'For privacy, the exact team address is hidden. Students see a 1,000-meter circle centered on an offset map location.';
        }
      }

      modeInputs.forEach(input => input.addEventListener('change', syncMode));
      const programInput = form.querySelector('#program');
      if (programInput) programInput.addEventListener('change', syncMode);
      syncMode();
    })();
  </script>
</body>
</html>
