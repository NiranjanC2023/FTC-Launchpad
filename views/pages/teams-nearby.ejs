<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Teams Near Me - FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Google Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <!-- Font Awesome for marker icon -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <header>
    
  </header>

  <main>
    <div class="container" id="teamsContainer">
      <a href="/join-form" class="btn btn-secondary back-button">← Edit Info</a>
      <h1>Teams Near You</h1>
      <p id="teamsStatus" class="subtitle">Looking for teams...</p>

      <div id="teamsList" class="teams-list">
        <!-- Teams will be rendered here -->
      </div>
    </div>
  </main>

  <!-- Server-provided teams array (replace on server) -->
  <script>
    // Expected shape: [{ name, lat, lon, contact }, ...]
    window.__TEAMS__ = <%- JSON.stringify(typeof teams !== 'undefined' ? teams : null) %>;
    window.__USER_COORDS__ = <%- JSON.stringify(typeof userCoords !== 'undefined' ? userCoords : null) %>;
  </script>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="/assets/js/main.js?v=8"></script>
</body>
</html>
