<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Sign In Required | FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
  <style>
    .auth-gate {
      min-height: calc(100vh - 120px);
      display: grid;
      place-items: center;
      padding: 48px 0 72px;
    }
    .auth-gate-card {
      width: min(760px, 100%);
      background: var(--surface);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
      padding: 36px;
    }
    .auth-gate-card h1 {
      margin: 0 0 12px;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 900;
      letter-spacing: -1px;
    }
    .auth-gate-card .subtitle {
      color: var(--text-secondary);
      margin-bottom: 28px;
      max-width: 56ch;
    }
    .auth-gate-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 18px;
      justify-content: center;
    }
    .auth-gate-actions .btn {
      min-width: 180px;
    }
    .auth-gate-note {
      color: var(--text-muted);
      margin: 0;
      font-size: 0.95rem;
    }
    @media (max-width: 640px) {
      .auth-gate-card { padding: 24px; }
      .auth-gate-actions .btn { width: 100%; }
    }
  </style>
</head>
<body class="auth-page">
  <header></header>

  <main class="auth-gate">
    <div class="container">
      <div class="auth-gate-card">
        <a href="/" class="btn btn-secondary back-button">Back Home</a>
        <h1>Sign in required</h1>
        <p class="subtitle">
          <%= destinationLabel ? ('Please log in or create an account to continue to ' + destinationLabel + '.') : 'Please log in or create an account to continue.' %>
        </p>

        <div class="auth-gate-actions">
          <a class="btn btn-primary" href="/login?next=<%= encodeURIComponent(nextPath || '/') %>">Log in</a>
          <a class="btn btn-secondary" href="/signup?next=<%= encodeURIComponent(nextPath || '/') %>">Sign up</a>
        </div>

        <p class="auth-gate-note">After you finish, we'll send you right back to where you were headed.</p>
      </div>
    </div>
  </main>

  <script src="/assets/js/main.js?v=8"></script>
</body>
</html>
