<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Sign Up — Join a Team</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
</head>
<body class="auth-page">
  <header></header>

  <main>
    <div class="container">
      <a href="/signup" class="btn btn-secondary back-button">← Back</a>
      <h1>Sign Up — Looking to Join a Team</h1>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form id="signupForm" method="POST" action="/signup">
        <input type="hidden" name="signupMode" value="seeker" />
        <input type="hidden" name="inviteToken" value="<%= inviteToken || '' %>" />

        <div class="mb-3">
          <label class="form-label">Full name</label>
          <input name="name" id="name" class="form-control" value="<%= values && values.name ? values.name : '' %>" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input name="email" id="email" type="email" class="form-control" value="<%= values && values.email ? values.email : '' %>" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input name="password" id="password" type="password" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Age</label>
          <input name="age" id="age" type="number" min="6" class="form-control" value="<%= values && values.age ? values.age : '' %>" />
        </div>
        <div class="mb-3">
          <label class="form-label">Phone</label>
          <input name="phone" id="phone" type="tel" class="form-control" value="<%= values && values.phone ? values.phone : '' %>" />
        </div>

        <div class="mb-3">
          <label class="form-label">Profile picture URL</label>
          <input name="profilePicture" type="url" class="form-control" value="<%= values && values.profilePicture ? values.profilePicture : '' %>" placeholder="https://example.com/photo.jpg" />
        </div>

        <div class="mb-3">
          <label class="form-label" for="interests">Interests / Roles</label>
          <input
            name="interests"
            id="interests"
            class="form-control"
            value="<%= values && values.interests ? values.interests : '' %>"
            placeholder="Example: programming, CAD, mechanical, driving, outreach"
          />
        </div>

        <div class="mb-3">
          <label class="form-label" for="experience">Experience</label>
          <textarea
            name="experience"
            id="experience"
            class="form-control"
            rows="4"
            placeholder="Example: beginner, 1 year in FTC, built robots before"
          ><%= values && values.experience ? values.experience : '' %></textarea>
        </div>

        <button class="btn btn-primary" type="submit">Create account</button>
      </form>

      <p style="margin-top:14px">Already have an account? <a href="/login">Log in</a></p>
    </div>
  </main>

  <script src="/assets/js/main.js?v=8"></script>
</body>
</html>
