<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | <%= team ? team.name : 'Manage Team' %></title>
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .dashboard-wrapper { padding: 40px 0 80px; }
        .page-header { border-bottom: none; margin-bottom: 40px; text-align: center !important; }
        .page-header h1 { font-size: 3.2rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 5px; }
        .page-header .subtitle { text-align: center; margin: 0; }
        .page-header .header-actions { display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 16px; }
        
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .stat-card { 
            background: var(--surface); border: 1px solid var(--border-color); border-radius: var(--radius-md);
            padding: 24px; display: flex; align-items: center; gap: 20px; box-shadow: var(--shadow-sm);
            transition: transform 0.2s ease;
        }
        .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
        .stat-icon { 
            width: 50px; height: 50px; border-radius: 12px; background: var(--accent-soft); 
            color: var(--accent-primary); display: grid; place-items: center; font-size: 1.4rem;
        }
        .stat-content h4 { margin: 0; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.5px; }
        .stat-content p { margin: 0; font-size: 1.3rem; font-weight: 800; color: var(--text-primary); }
        .stat-content .location-value { font-size: 1.05rem; line-height: 1.25; overflow-wrap: anywhere; }

        .dashboard-panel { 
            background: var(--surface); border: 1px solid var(--border-color); border-radius: var(--radius-lg); 
            overflow: visible; box-shadow: var(--shadow-md); height: 100%;
        }
        .panel-head { 
            padding: 24px; background: var(--surface-soft); border-bottom: 1px solid var(--border-color);
            display: flex; justify-content: space-between; align-items: center;
        }
        .panel-head h3 { margin: 0; font-size: 1.2rem; font-weight: 800; display: flex; align-items: center; gap: 10px; }
        .panel-body { padding: 30px; }

        .recruit-card {
            background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: var(--radius-md);
            padding: 20px; margin-bottom: 15px; transition: all 0.2s ease; position: relative; overflow: hidden;
        }
        .recruit-card:hover { border-color: var(--accent-primary); transform: scale(1.01); background: var(--surface); }
        .recruit-card::after { 
            content: ''; position: absolute; left: 0; top: 0; height: 100%; width: 4px; 
            background: var(--accent-secondary); opacity: 0.6;
        }

        .btn-update { 
            background: var(--accent-primary); color: white; border: none; padding: 15px; 
            font-size: 1.1rem; border-radius: var(--radius-sm); font-weight: 800;
        }
        .btn-update:hover { background: #173d36; color: white; transform: translateY(-2px); }

        .status-pill { padding: 4px 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 900; background: #e0f2fe; color: #0369a1; }
        .recruit-action-row { display: flex; justify-content: flex-end; gap: 10px; flex-wrap: wrap; }
        .btn-rounded { border-radius: 9999px; }
        .btn-rounded.btn-sm { padding: 0.5rem 1rem; }
        .btn-rounded:disabled { opacity: 0.55; cursor: not-allowed; }
        .status-modal {
            position: fixed;
            inset: 0;
            z-index: 1000;
            display: grid;
            place-items: center;
            padding: 30px;
        }
        .status-modal-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(15, 23, 42, 0.65);
            backdrop-filter: blur(2px);
        }
        .status-modal-panel {
            position: relative;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 30px 80px rgba(15,23,42,0.18);
            width: min(620px, 100%);
            max-height: min(90vh, 720px);
            overflow-y: auto;
            padding: 28px;
            z-index: 1;
        }
        .status-modal.hidden { display: none; }
        .status-modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
        .status-modal-header h2 { margin: 0; font-size: 1.4rem; }
        .btn-ghost { background: transparent; border: none; color: #475569; font-size: 1.5rem; line-height: 1; cursor: pointer; }
        .recruit-name-button {
            appearance: none;
            background: transparent;
            border: 0;
            color: var(--accent-primary);
            cursor: pointer;
            font: inherit;
            font-weight: 800;
            padding: 0;
            text-align: left;
        }
        .recruit-name-button:hover,
        .recruit-name-button:focus {
            text-decoration: underline;
        }
        .recruit-info-grid {
            display: grid;
            grid-template-columns: 140px 1fr;
            gap: 12px 18px;
        }
        .recruit-info-grid dt {
            color: #64748b;
            font-weight: 800;
            margin: 0;
        }
        .recruit-info-grid dd {
            color: #0f172a;
            margin: 0;
            overflow-wrap: anywhere;
            white-space: pre-wrap;
        }
        @media (max-width: 640px) {
            .recruit-info-grid { grid-template-columns: 1fr; gap: 4px 0; }
            .recruit-info-grid dd { margin-bottom: 10px; }
        }
    </style>
</head>
<body class="dashboard-page">
    <header></header>
    <div class="container dashboard-wrapper">
        <div class="page-header">
            <h1>Command Center</h1>
            <% if (team) { %>
                <p class="subtitle">Managing <strong><%= team.name %></strong> · Team #<%= team.teamNumber %></p>
            <% } else { %>
                <p class="subtitle">You are not currently managing a team.</p>
            <% } %>
            <div class="header-actions">
                <a href="/teams-nearby" class="btn btn-secondary"><i class="fa-solid fa-earth-americas"></i> View Listing</a>
            </div>
        </div>
        
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-success" style="background: #d1fae5; color: #065f46; border-color: #a7f3d0;">
                <i class="fa-solid fa-circle-check"></i> <%= message %>
            </div>
        <% } %>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <% if (team) { %>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon" style="background: #fff7ed; color: #ea580c;"><i class="fa-solid fa-location-crosshairs"></i></div>
                    <div class="stat-content">
                        <h4>Base Location</h4>
                        <p class="location-value"><%= [team.city, team.state].filter(Boolean).join(', ') || team.country || 'Not set' %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #ecfeff; color: #0891b2;"><i class="fa-solid fa-hourglass-half"></i></div>
                    <div class="stat-content">
                        <h4>Time as a Team</h4>
                        <p><%= teamTenureLabel || 'Not available' %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-users-viewfinder"></i></div>
                    <div class="stat-content">
                        <h4>Total Recruits</h4>
                        <p><%= recruits ? recruits.length : 0 %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #fef3c7; color: #b45309;"><i class="fa-solid fa-star"></i></div>
                    <div class="stat-content">
                        <h4>Accepted</h4>
                        <p><%= typeof acceptedCount !== 'undefined' ? acceptedCount : 0 %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #ede9fe; color: #7c3aed;"><i class="fa-solid fa-hourglass-half"></i></div>
                    <div class="stat-content">
                        <h4>Waitlisted</h4>
                        <p><%= typeof waitlistCount !== 'undefined' ? waitlistCount : 0 %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #fee2e2; color: #b91c1c;"><i class="fa-solid fa-ban"></i></div>
                    <div class="stat-content">
                        <h4>Rejected</h4>
                        <p><%= typeof rejectedCount !== 'undefined' ? rejectedCount : 0 %></p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="dashboard-panel">
                        <div class="panel-head">
                            <h3><i class="fa-solid fa-sliders"></i> Settings</h3>
                        </div>
                        <div class="panel-body">
                            <form action="/manage-team/update" method="POST" class="text-left">
                                <div class="mb-3">
                                    <label class="form-label">Recruiting Bio</label>
                                    <textarea name="notes" class="form-control" rows="8" placeholder="Tell students about your team culture..."><%= team.notes %></textarea>
                                    <small class="text-muted">This bio appears on the public map.</small>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Awards Achieved</label>
                                    <div class="team-history-panel" style="margin: 0;">
                                        <% if (team.awardHistory && team.awardHistory.length) { %>
                                            <ul style="margin: 0; padding-left: 18px;">
                                                <% team.awardHistory.forEach(function(entry) { %>
                                                    <li>🏅 <%= entry %></li>
                                                <% }) %>
                                            </ul>
                                        <% } else { %>
                                            No award history listed yet.
                                        <% } %>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Competition History</label>
                                    <div class="team-history-panel" style="margin: 0;">
                                        <% if (team.advancementHistory && team.advancementHistory.length) { %>
                                            <ul style="margin: 0; padding-left: 18px;">
                                                <% team.advancementHistory.forEach(function(entry) { %>
                                                    <li>🏁 <%= entry %></li>
                                                <% }) %>
                                            </ul>
                                        <% } else { %>
                                            No competition history listed yet.
                                        <% } %>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="checkbox" style="margin: 0; padding: 15px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); cursor: pointer; display: block;">
                                        <input type="checkbox" name="recruiting" <%= team.recruiting ? 'checked' : '' %>>
                                        <span style="margin-left: 8px; font-weight: 800;">Actively Recruiting</span>
                                        <p class="small text-muted" style="margin: 5px 0 0 25px;">Toggle visibility on the recruitment map.</p>
                                    </label>
                                </div>
                                <hr>
                                <button type="submit" class="btn btn-update btn-block">
                                    <i class="fa-solid fa-circle-check"></i> Save Changes
                                </button>
                            </form>

                            <hr style="border-top: 1px solid var(--border-color); margin: 30px 0;">
                            <div class="panel-body" style="padding: 0;">
                                <% const isPrimary = (user && user.email && team && team.contact && user.email.toLowerCase() === team.contact.toLowerCase()); %>
                                <% const isCaptain = (user && user.role && String(user.role).trim().toLowerCase() === 'captain'); %>
                                <h4 style="margin: 0 0 18px; font-size: 1rem; font-weight: 700;">Team Managers</h4>
                                <% const managerCaptainActionAllowed = isPrimary; %>
                                <% const currentCaptain = teamManagers && teamManagers.find(function(manager) { return manager.role && String(manager.role).trim().toLowerCase() === 'captain'; }); %>
                                <% if (managerCaptainActionAllowed && teamManagers && teamManagers.length > 0) { %>
                                    <form action="/manage-team/managers/captain" method="POST" class="text-left" style="margin-bottom: 18px;">
                                        <div class="mb-3">
                                            <label class="form-label">Team Captain</label>
                                            <select name="managerUserId" class="form-control" required>
                                                <option value=""><%= currentCaptain ? 'Current captain: ' + currentCaptain.name : 'Select a manager to promote' %></option>
                                                <% teamManagers.forEach(function(manager) { %>
                                                    <option value="<%= manager._id %>" <%= currentCaptain && String(manager._id) === String(currentCaptain._id) ? 'selected' : '' %>><%= manager.name %><%= manager.role && String(manager.role).trim().toLowerCase() === 'captain' ? ' (captain)' : '' %></option>
                                                <% }); %>
                                            </select>
                                        </div>
                                        <button type="submit" class="btn btn-primary btn-block" style="width: 100%;">
                                            <i class="fa-solid fa-star"></i> Save Captain
                                        </button>
                                    </form>
                                <% } %>
                                <% if (teamManagers && teamManagers.length > 0) { %>
                                    <ul style="list-style: none; padding: 0; margin: 0 0 22px 0;">
                                        <% teamManagers.forEach(function(manager) { %>
                                            <li class="manager-card" style="position: relative; margin-bottom: 10px; padding: 12px 14px 20px 14px; padding-right: 56px; border: 1px solid var(--border-color); border-radius: var(--radius-md); background: var(--surface); display: flex; justify-content: space-between; align-items: flex-start; gap: 12px;">
                                                <div class="manager-card-main">
                                                    <strong><%= manager.name %></strong>
                                                    <% if (manager.primary) { %>
                                                        <span class="status-pill" style="background: #fee2e2; color: #b91c1c; margin-left: 8px;"><i class="fa-solid fa-star" style="margin-right:4px;"></i>Primary</span>
                                                    <% } %>
                                                    <% if (manager.role && String(manager.role).trim().toLowerCase() === 'captain') { %>
                                                        <span class="status-pill" style="background: #ede9fe; color: #7c3aed; margin-left: 8px;">Captain</span>
                                                    <% } %>
                                                </div>
                                                <% const isSelf = (user && manager && String(manager._id) === String(user._id)); %>
                                                <% const hasAction = isPrimary || isSelf || isCaptain; %>
                                                <% if (hasAction) { %>
                                                    <details class="manager-actions-dropdown">
                                                        <summary aria-label="Toggle manager actions" role="button"><span aria-hidden="true">▾</span></summary>
                                                        <div class="actions-menu">
                                                            <% if (isPrimary) { %>
                                                                <form action="/manage-team/managers/captain" method="POST">
                                                                    <input type="hidden" name="managerUserId" value="<%= manager._id %>" />
                                                                    <button type="submit" class="btn btn-tertiary action-button">
                                                                        <% if (manager.role && String(manager.role).trim().toLowerCase() === 'captain') { %>
                                                                            Remove Captain
                                                                        <% } else { %>
                                                                            Set as Captain
                                                                        <% } %>
                                                                    </button>
                                                                </form>
                                                            <% } %>
                                                            <% if (!manager.primary && (isPrimary || isSelf || isCaptain)) { %>
                                                                <form action="/manage-team/managers/remove" method="POST">
                                                                    <input type="hidden" name="managerUserId" value="<%= manager._id %>" />
                                                                    <button type="submit" class="btn btn-tertiary action-button">Remove</button>
                                                                </form>
                                                            <% } %>
                                                        </div>
                                                    </details>
                                                <% } %>
                                            </li>
                                        <% }); %>
                                    </ul>
                                <% } else { %>
                                    <p class="text-muted" style="margin-bottom: 18px;">Currently only the primary contact has management access.</p>
                                <% } %>

                                <form action="/manage-team/managers/add" method="POST" class="text-left">
                                    <div class="mb-3">
                                        <label class="form-label">Add team manager</label>
                                        <% if (managerCandidates && managerCandidates.length > 0) { %>
                                            <select name="managerUserId" class="form-control" required>
                                                <option value="">Select a team member</option>
                                                <% managerCandidates.forEach(function(member) { %>
                                                    <option value="<%= member._id %>"><%= member.name %></option>
                                                <% }); %>
                                            </select>
                                        <% } else { %>
                                            <div class="alert alert-info" style="margin: 0;">No eligible team members have signed up yet or they are already managers.</div>
                                        <% } %>
                                    </div>
                                    <% if (managerCandidates && managerCandidates.length > 0) { %>
                                        <button type="submit" class="btn btn-primary btn-block" style="width: 100%;">
                                            <i class="fa-solid fa-user-plus"></i> Add Manager
                                        </button>
                                    <% } %>
                                </form>

                                <hr style="border-top: 1px solid var(--border-color); margin: 30px 24px;">

                                <form action="/manage-team/invite" method="POST" class="text-left" style="margin: 0 24px 24px;">
                                    <div class="mb-3">
                                        <label class="form-label">Invite a new manager by email</label>
                                        <input type="email" name="email" class="form-control" placeholder="Enter their email" required />
                                        <small class="form-text text-muted">If they don’t have an account yet, they’ll be asked to sign up with this email.</small>
                                    </div>
                                    <button type="submit" class="btn btn-secondary btn-block" style="width: 100%;">
                                        <i class="fa-solid fa-envelope"></i> Send Invitation
                                    </button>
                                </form>
                            </div>

                            <hr style="border-top: 1px solid var(--border-color); margin: 30px 0;">
                            <div class="danger-zone" style="text-align: left;">
                                <h4 style="color: #dc2626; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; margin-bottom: 5px;">Danger Zone</h4>
                                <p class="small text-muted" style="margin-bottom: 15px;">Deleting your team will remove it from the map and recruitment feed. This is permanent.</p>
                                <form action="/manage-team/delete" method="POST" onsubmit="return confirm('Are you absolutely sure you want to delete your team? This action cannot be undone.');">
                                    <button type="submit" class="btn btn-tertiary btn-block" style="color: #dc2626 !important; border-color: #fca5a5 !important;">
                                        <i class="fa-solid fa-trash-can"></i> Delete Team Permanently
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="dashboard-panel">
                        <div class="panel-head">
                            <h3><i class="fa-solid fa-user-plus"></i> Recruitment Feed</h3>
                            <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; justify-content:flex-end;">
                                <% if (isPrimary || isCaptain) { %>
                                    <form action="/manage-team/recruitment/clear" method="POST" onsubmit="return confirm('Clear every recruit currently shown in the recruitment feed? This testing action cannot be undone.');" style="margin:0;">
                                        <button type="submit" class="btn btn-tertiary btn-sm" style="color:#7c3aed !important; border-color:#c4b5fd !important;">
                                            <i class="fa-solid fa-broom"></i> Clear Feed
                                        </button>
                                    </form>
                                <% } %>
                                <span class="badge" style="background: var(--accent-secondary);"><%= recruits.length %> Recent</span>
                            </div>
                        </div>
                        <div class="panel-body">
                            <div class="list-group" style="margin: 0;">
                                <% if (recruits && recruits.length > 0) { %>
                                    <% recruits.forEach(function(recruit) { %>
                                        <div class="recruit-card">
                                            <div class="row" style="display: flex; align-items: center;">
                                                <div class="col-sm-8">
                                                    <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
                                                        <h4 style="margin: 0;">
                                                            <button
                                                                type="button"
                                                                class="recruit-name-button"
                                                                data-recruit-info
                                                                data-name="<%= recruit.name || '' %>"
                                                                data-age="<%= recruit.age || '' %>"
                                                                data-email="<%= recruit.email || '' %>"
                                                                data-phone="<%= recruit.phone || '' %>"
                                                                data-interests="<%= recruit.interests || '' %>"
                                                                data-experience="<%= recruit.experience || '' %>"><%= recruit.name %></button>
                                                        </h4>
                                                        <% if (recruit.applicationTeam && String(recruit.applicationTeam) === String(team._id)) { %>
                                                            <span class="status-pill" style="background: <%= recruit.applicationStatus === 'accepted' ? '#dcfce7' : recruit.applicationStatus === 'waitlisted' ? '#eef2ff' : '#fee2e2' %>; color: <%= recruit.applicationStatus === 'accepted' ? '#166534' : recruit.applicationStatus === 'waitlisted' ? '#4338ca' : '#991b1b' %>;">
                                                                <%= recruit.applicationStatus.charAt(0).toUpperCase() + recruit.applicationStatus.slice(1) %>
                                                            </span>
                                                        <% } %>
                                                    </div>
                                                    <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px;">
                                                        <span class="label label-default" style="font-weight: 800;">Age <%= recruit.age %></span>
                                                        <span class="label label-info" style="background: var(--bg-secondary); color: var(--accent-primary); font-weight: 800;"><%= recruit.interests %></span>
                                                    </div>
                                                    <p class="small text-muted" style="margin: 0;"><strong>Background:</strong> <%= recruit.experience %></p>
                                                </div>
                                                <div class="col-sm-4 text-right recruit-actions">
                                                    <% const status = (recruit.applicationTeam && String(recruit.applicationTeam) === String(team._id)) ? recruit.applicationStatus : null; %>
                                                    <% const isFinal = status === 'accepted' || status === 'rejected'; %>
                                                    <div class="recruit-action-row">
                                                        <button type="button" class="btn btn-danger btn-sm btn-rounded recruit-action-btn" data-action="reject" data-recruit-id="<%= recruit._id %>" data-recruit-name="<%= recruit.name %>" <%= isFinal ? 'disabled' : '' %>>
                                                            <i class="fa-solid fa-xmark"></i> Reject
                                                        </button>
                                                        <% if (status !== 'waitlisted' && !isFinal) { %>
                                                            <button type="button" class="btn btn-warning btn-sm btn-rounded recruit-action-btn" data-action="waitlist" data-recruit-id="<%= recruit._id %>" data-recruit-name="<%= recruit.name %>">
                                                                <i class="fa-solid fa-clock"></i> Waitlist
                                                            </button>
                                                        <% } %>
                                                        <button type="button" class="btn btn-primary btn-sm btn-rounded recruit-action-btn" data-action="accept" data-recruit-id="<%= recruit._id %>" data-recruit-name="<%= recruit.name %>" <%= isFinal ? 'disabled' : '' %>>
                                                            <i class="fa-solid fa-check"></i> Accept
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div class="text-center" style="padding: 50px 0;">
                                        <i class="fa-solid fa-hourglass-empty" style="font-size: 3rem; color: var(--border-color); margin-bottom: 15px; display: block;"></i>
                                        <p class="text-muted">No recruits available right now. Check back soon!</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="dashboard-panel" style="margin-top: 30px;">
                        <div class="panel-head">
                            <h3><i class="fa-solid fa-list-check"></i> Waitlist</h3>
                            <span class="badge" style="background: var(--accent-secondary);"><%= waitlisted.length %> Waiting</span>
                        </div>
                        <div class="panel-body">
                            <% if (waitlisted && waitlisted.length > 0) { %>
                                <div class="list-group">
                                    <% waitlisted.forEach(function(waitRecruit) { %>
                                        <div class="recruit-card" style="margin-bottom: 12px;">
                                            <div style="display:flex; justify-content:space-between; align-items:center; gap:12px;">
                                                <div>
                                                    <h4 style="margin:0;">
                                                        <button
                                                            type="button"
                                                            class="recruit-name-button"
                                                            data-recruit-info
                                                            data-name="<%= waitRecruit.name || '' %>"
                                                            data-age="<%= waitRecruit.age || '' %>"
                                                            data-email="<%= waitRecruit.email || '' %>"
                                                            data-phone="<%= waitRecruit.phone || '' %>"
                                                            data-interests="<%= waitRecruit.interests || '' %>"
                                                            data-experience="<%= waitRecruit.experience || '' %>"><%= waitRecruit.name %></button>
                                                    </h4>
                                                    <p class="small text-muted" style="margin:4px 0 0;">Email: <%= waitRecruit.email %></p>
                                                </div>
                                                <span class="status-pill" style="background: #eef2ff; color:#4338ca;">Waitlisted</span>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="text-center" style="padding: 40px 0;">
                                    <p class="text-muted" style="margin:0;">No one is currently on the waitlist.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div id="statusActionModal" class="status-modal hidden">
                <div class="status-modal-backdrop"></div>
                <div class="status-modal-panel">
                    <div class="status-modal-header">
                        <h2 id="statusActionTitle">Send team response</h2>
                        <button type="button" id="statusActionClose" class="btn btn-ghost" aria-label="Close">×</button>
                    </div>
                    <p id="statusActionInfo" style="margin:0 0 18px; color:#475569;"></p>
                    <form id="statusActionForm" method="POST">
                        <input type="hidden" name="action" value="">
                        <div class="mb-3 status-custom-group">
                            <label class="form-label" for="statusCustomMessage">Custom response</label>
                            <textarea id="statusCustomMessage" name="customMessage" class="form-control" rows="5" placeholder="Add a custom message to the recipient..."></textarea>
                            <p class="small text-muted" style="margin-top:8px;">This message will be included in the email to the student.</p>
                        </div>
                        <div style="display:flex; justify-content:flex-end; gap: 12px; margin-top:18px;">
                            <button type="button" id="statusActionCancel" class="btn btn-secondary">Cancel</button>
                            <button type="submit" class="btn btn-primary">Send Email</button>
                        </div>
                    </form>
                </div>
            </div>

            <div id="recruitInfoModal" class="status-modal hidden">
                <div class="status-modal-backdrop"></div>
                <div class="status-modal-panel">
                    <div class="status-modal-header">
                        <h2 id="recruitInfoTitle">Applicant Info</h2>
                        <button type="button" id="recruitInfoClose" class="btn btn-ghost" aria-label="Close">×</button>
                    </div>
                    <dl class="recruit-info-grid">
                        <dt>Age</dt>
                        <dd id="recruitInfoAge"></dd>
                        <dt>Email</dt>
                        <dd id="recruitInfoEmail"></dd>
                        <dt>Phone</dt>
                        <dd id="recruitInfoPhone"></dd>
                        <dt>Interests</dt>
                        <dd id="recruitInfoInterests"></dd>
                        <dt>Background</dt>
                        <dd id="recruitInfoExperience"></dd>
                    </dl>
                </div>
            </div>

            <script>
                (function() {
                    const modal = document.getElementById('statusActionModal');
                    const form = document.getElementById('statusActionForm');
                    const actionTitle = document.getElementById('statusActionTitle');
                    const actionInfo = document.getElementById('statusActionInfo');
                    const messageGroup = document.querySelector('.status-custom-group');
                    const messageField = document.getElementById('statusCustomMessage');
                    const modalClose = document.getElementById('statusActionClose');
                    const modalCancel = document.getElementById('statusActionCancel');

                    function closeModal() {
                        modal.classList.add('hidden');
                        messageField.value = '';
                    }

                    function openModal(action, recruitId, recruitName) {
                        form.action = '/manage-team/recruit/' + recruitId + '/status';
                        form.querySelector('[name="action"]').value = action;
                        if (action === 'accept') {
                            actionTitle.textContent = 'Send Acceptance Email';
                            actionInfo.textContent = 'Add a custom message to help the student understand next steps.';
                            messageGroup.style.display = '';
                        } else if (action === 'waitlist') {
                            actionTitle.textContent = 'Send Waitlist Email';
                            actionInfo.textContent = 'Add a custom message to explain the waitlist process and next steps.';
                            messageGroup.style.display = '';
                        } else {
                            actionTitle.textContent = 'Send Rejection Email';
                            actionInfo.textContent = 'A confirmation will be required before the rejection email is sent.';
                            messageGroup.style.display = 'none';
                        }
                        modal.classList.remove('hidden');
                        messageField.focus();
                    }

                    document.querySelectorAll('.recruit-action-btn').forEach(button => {
                        button.addEventListener('click', function() {
                            const action = this.dataset.action;
                            const recruitId = this.dataset.recruitId;
                            const recruitName = this.dataset.recruitName;

                            if (action === 'reject') {
                                const confirmed = window.confirm('Send a rejection email to ' + recruitName + '? This cannot be undone.');
                                if (confirmed) {
                                    openModal(action, recruitId, recruitName);
                                    messageGroup.style.display = 'none';
                                }
                                return;
                            }

                            openModal(action, recruitId, recruitName);
                        });
                    });

                    modalCancel.addEventListener('click', closeModal);
                    modalClose.addEventListener('click', closeModal);

                    form.addEventListener('submit', function(event) {
                        const action = form.querySelector('[name="action"]').value;
                        const message = messageField.value.trim();
                        if (action === 'waitlist' || action === 'accept') {
                            if (!window.confirm('Send this email to the recruit now?')) {
                                event.preventDefault();
                                return;
                            }
                        }
                    });

                    const infoModal = document.getElementById('recruitInfoModal');
                    const infoClose = document.getElementById('recruitInfoClose');
                    const infoFields = {
                        title: document.getElementById('recruitInfoTitle'),
                        age: document.getElementById('recruitInfoAge'),
                        email: document.getElementById('recruitInfoEmail'),
                        phone: document.getElementById('recruitInfoPhone'),
                        interests: document.getElementById('recruitInfoInterests'),
                        experience: document.getElementById('recruitInfoExperience')
                    };

                    function fillInfoField(key, value) {
                        infoFields[key].textContent = value && value.trim() ? value : 'Not provided';
                    }

                    function closeInfoModal() {
                        infoModal.classList.add('hidden');
                    }

                    document.querySelectorAll('[data-recruit-info]').forEach(button => {
                        button.addEventListener('click', function() {
                            infoFields.title.textContent = this.dataset.name || 'Applicant Info';
                            fillInfoField('age', this.dataset.age || '');
                            fillInfoField('email', this.dataset.email || '');
                            fillInfoField('phone', this.dataset.phone || '');
                            fillInfoField('interests', this.dataset.interests || '');
                            fillInfoField('experience', this.dataset.experience || '');
                            infoModal.classList.remove('hidden');
                        });
                    });

                    infoClose.addEventListener('click', closeInfoModal);
                    infoModal.querySelector('.status-modal-backdrop').addEventListener('click', closeInfoModal);
                })();
            </script>

        <% } else { %>
            <div class="alert alert-info">
                You haven't registered a team yet. <a href="/team-register" class="alert-link">Register your team now</a> to start managing recruits.
            </div>
        <% } %>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.manager-actions-dropdown').forEach(function(dropdown) {
                dropdown.addEventListener('toggle', function() {
                    var card = dropdown.closest('.manager-card');
                    if (!card) return;
                    if (dropdown.open) {
                        card.classList.add('manager-card-open');
                    } else {
                        card.classList.remove('manager-card-open');
                    }
                });
            });
        });
    </script>
    <script src="/assets/js/main.js"></script>
</body>
</html>
