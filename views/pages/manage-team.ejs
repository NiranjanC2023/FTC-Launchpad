<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | <%= team ? team.name : 'Manage Team' %></title>
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .dashboard-wrapper { padding: 40px 0 80px; }
        .page-header { border-bottom: none; margin-bottom: 40px; text-align: left !important; }
        .page-header h1 { font-size: 3.2rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 5px; }
        
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .stat-card { 
            background: var(--surface); border: 1px solid var(--border-color); border-radius: var(--radius-md);
            padding: 24px; display: flex; align-items: center; gap: 20px; box-shadow: var(--shadow-sm);
            transition: transform 0.2s ease;
        }
        .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
        .stat-icon { 
            width: 50px; height: 50px; border-radius: 12px; background: var(--accent-soft); 
            color: var(--accent-primary); display: grid; place-items: center; font-size: 1.4rem;
        }
        .stat-content h4 { margin: 0; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.5px; }
        .stat-content p { margin: 0; font-size: 1.3rem; font-weight: 800; color: var(--text-primary); }

        .dashboard-panel { 
            background: var(--surface); border: 1px solid var(--border-color); border-radius: var(--radius-lg); 
            overflow: hidden; box-shadow: var(--shadow-md); height: 100%;
        }
        .panel-head { 
            padding: 24px; background: var(--surface-soft); border-bottom: 1px solid var(--border-color);
            display: flex; justify-content: space-between; align-items: center;
        }
        .panel-head h3 { margin: 0; font-size: 1.2rem; font-weight: 800; display: flex; align-items: center; gap: 10px; }
        .panel-body { padding: 30px; }

        .recruit-card {
            background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: var(--radius-md);
            padding: 20px; margin-bottom: 15px; transition: all 0.2s ease; position: relative; overflow: hidden;
        }
        .recruit-card:hover { border-color: var(--accent-primary); transform: scale(1.01); background: var(--surface); }
        .recruit-card::after { 
            content: ''; position: absolute; left: 0; top: 0; height: 100%; width: 4px; 
            background: var(--accent-secondary); opacity: 0.6;
        }

        .btn-update { 
            background: var(--accent-primary); color: white; border: none; padding: 15px; 
            font-size: 1.1rem; border-radius: var(--radius-sm); font-weight: 800;
        }
        .btn-update:hover { background: #173d36; color: white; transform: translateY(-2px); }

        .status-pill { padding: 4px 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 900; background: #e0f2fe; color: #0369a1; }
    </style>
</head>
<body class="dashboard-page">
    <header></header>
    <div class="container dashboard-wrapper">
        <div class="page-header">
            <div class="row">
                <div class="col-sm-8">
                    <h1>Command Center</h1>
                    <% if (team) { %>
                        <p class="subtitle" style="text-align: left; margin: 0;">Managing <strong><%= team.name %></strong> · Team #<%= team.teamNumber %></p>
                    <% } else { %>
                        <p class="subtitle" style="text-align: left; margin: 0;">You are not currently managing a team.</p>
                    <% } %>
                </div>
                <div class="col-sm-4 text-right" style="padding-top: 25px;">
                    <a href="/teams-nearby" class="btn btn-secondary"><i class="fa-solid fa-earth-americas"></i> View Listing</a>
                </div>
            </div>
        </div>
        
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-success" style="background: #d1fae5; color: #065f46; border-color: #a7f3d0;">
                <i class="fa-solid fa-circle-check"></i> <%= message %>
            </div>
        <% } %>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <% if (team) { %>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-users-viewfinder"></i></div>
                    <div class="stat-content">
                        <h4>Total Recruits</h4>
                        <p><%= recruits ? recruits.length : 0 %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #ecfdf5; color: #059669;"><i class="fa-solid fa-shield-halved"></i></div>
                    <div class="stat-content">
                        <h4>Verification</h4>
                        <p><span class="status-pill">Official FIRST Team</span></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #fff7ed; color: #ea580c;"><i class="fa-solid fa-location-crosshairs"></i></div>
                    <div class="stat-content">
                        <h4>Base Location</h4>
                        <p><%= team.city %>, <%= team.state %></p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="dashboard-panel">
                        <div class="panel-head">
                            <h3><i class="fa-solid fa-sliders"></i> Settings</h3>
                        </div>
                        <div class="panel-body">
                            <form action="/manage-team/update" method="POST" class="text-left">
                                <div class="mb-3">
                                    <label class="form-label">Recruiting Bio</label>
                                    <textarea name="notes" class="form-control" rows="8" placeholder="Tell students about your team culture..."><%= team.notes %></textarea>
                                    <small class="text-muted">This bio appears on the public map.</small>
                                </div>
                                <div class="mb-3">
                                    <label class="checkbox" style="margin: 0; padding: 15px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); cursor: pointer; display: block;">
                                        <input type="checkbox" name="recruiting" <%= team.recruiting ? 'checked' : '' %>>
                                        <span style="margin-left: 8px; font-weight: 800;">Actively Recruiting</span>
                                        <p class="small text-muted" style="margin: 5px 0 0 25px;">Toggle visibility on the recruitment map.</p>
                                    </label>
                                </div>
                                <hr>
                                <button type="submit" class="btn btn-update btn-block">
                                    <i class="fa-solid fa-circle-check"></i> Save Changes
                                </button>
                            </form>

                            <hr style="border-top: 1px solid var(--border-color); margin: 30px 0;">
                            <div class="panel-body" style="padding: 0;">
                                <h4 style="margin: 0 0 18px; font-size: 1rem; font-weight: 700;">Team Managers</h4>
                                <% if (teamManagers && teamManagers.length > 0) { %>
                                    <ul style="list-style: none; padding: 0; margin: 0 0 22px 0;">
                                        <% teamManagers.forEach(function(manager) { %>
                                            <li style="margin-bottom: 10px; padding: 12px 14px; border: 1px solid var(--border-color); border-radius: var(--radius-md); background: var(--surface); display: flex; justify-content: space-between; align-items: center; gap: 12px;">
                                                <span><strong><%= manager.name %></strong> • <%= manager.email %></span>
                                                <form action="/manage-team/managers/remove" method="POST" style="margin:0;">
                                                    <input type="hidden" name="managerUserId" value="<%= manager._id %>" />
                                                    <button type="submit" class="btn btn-tertiary" style="padding: 8px 12px; font-size:0.88rem;">Remove</button>
                                                </form>
                                            </li>
                                        <% }); %>
                                    </ul>
                                <% } else { %>
                                    <p class="text-muted" style="margin-bottom: 18px;">Currently only the primary contact has management access.</p>
                                <% } %>

                                <form action="/manage-team/managers/add" method="POST" class="text-left">
                                    <div class="mb-3">
                                        <label class="form-label">Add team manager</label>
                                        <% if (managerCandidates && managerCandidates.length > 0) { %>
                                            <select name="managerUserId" class="form-control" required>
                                                <option value="">Select a team member</option>
                                                <% managerCandidates.forEach(function(member) { %>
                                                    <option value="<%= member._id %>"><%= member.name %> — <%= member.email %></option>
                                                <% }); %>
                                            </select>
                                        <% } else { %>
                                            <div class="alert alert-info" style="margin: 0;">No eligible team members have signed up yet or they are already managers.</div>
                                        <% } %>
                                    </div>
                                    <% if (managerCandidates && managerCandidates.length > 0) { %>
                                        <button type="submit" class="btn btn-primary btn-block" style="width: 100%;">
                                            <i class="fa-solid fa-user-plus"></i> Add Manager
                                        </button>
                                    <% } %>
                                </form>

                                <hr style="border-top: 1px solid var(--border-color); margin: 30px 24px;">

                                <form action="/manage-team/invite" method="POST" class="text-left" style="margin: 0 24px 24px;">
                                    <div class="mb-3">
                                        <label class="form-label">Invite a new manager by email</label>
                                        <input type="email" name="email" class="form-control" placeholder="Enter their email" required />
                                        <small class="form-text text-muted">If they don’t have an account yet, they’ll be asked to sign up with this email.</small>
                                    </div>
                                    <button type="submit" class="btn btn-secondary btn-block" style="width: 100%;">
                                        <i class="fa-solid fa-envelope"></i> Send Invitation
                                    </button>
                                </form>
                            </div>

                            <hr style="border-top: 1px solid var(--border-color); margin: 30px 0;">
                            <div class="danger-zone" style="text-align: left;">
                                <h4 style="color: #dc2626; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; margin-bottom: 5px;">Danger Zone</h4>
                                <p class="small text-muted" style="margin-bottom: 15px;">Deleting your team will remove it from the map and recruitment feed. This is permanent.</p>
                                <form action="/manage-team/delete" method="POST" onsubmit="return confirm('Are you absolutely sure you want to delete your team? This action cannot be undone.');">
                                    <button type="submit" class="btn btn-tertiary btn-block" style="color: #dc2626 !important; border-color: #fca5a5 !important;">
                                        <i class="fa-solid fa-trash-can"></i> Delete Team Permanently
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="dashboard-panel">
                        <div class="panel-head">
                            <h3><i class="fa-solid fa-user-plus"></i> Recruitment Feed</h3>
                            <span class="badge" style="background: var(--accent-secondary);"><%= recruits.length %> Recent</span>
                        </div>
                        <div class="panel-body">
                            <div class="list-group" style="margin: 0;">
                                <% if (recruits && recruits.length > 0) { %>
                                    <% recruits.forEach(function(recruit) { %>
                                        <div class="recruit-card">
                                            <div class="row" style="display: flex; align-items: center;">
                                                <div class="col-sm-8">
                                                    <h4 style="margin: 0 0 10px; color: var(--accent-primary); font-weight: 800;"><%= recruit.name %></h4>
                                                    <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px;">
                                                        <span class="label label-default" style="font-weight: 800;">Age <%= recruit.age %></span>
                                                        <span class="label label-info" style="background: var(--bg-secondary); color: var(--accent-primary); font-weight: 800;"><%= recruit.interests %></span>
                                                    </div>
                                                    <p class="small text-muted" style="margin: 0;"><strong>Background:</strong> <%= recruit.experience %></p>
                                                </div>
                                                <div class="col-sm-4 text-right">
                                                    <a href="/manage-team/contact/<%= recruit._id %>" class="btn btn-success btn-sm">
                                                        <i class="fa-solid fa-envelope"></i> Reach Out
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div class="text-center" style="padding: 50px 0;">
                                        <i class="fa-solid fa-hourglass-empty" style="font-size: 3rem; color: var(--border-color); margin-bottom: 15px; display: block;"></i>
                                        <p class="text-muted">No recruits available right now. Check back soon!</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="alert alert-info">
                You haven't registered a team yet. <a href="/team-register" class="alert-link">Register your team now</a> to start managing recruits.
            </div>
        <% } %>
    </div>
    <script src="/assets/js/main.js"></script>
</body>
</html>