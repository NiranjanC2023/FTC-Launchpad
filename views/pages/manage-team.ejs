                                <form action="/manage-team/invite" method="POST" class="text-left" style="margin: 0 24px 24px; text-align: left;">
                                    <div class="mb-3">
                                        <label class="form-label">Invite a new member by email</label>
                                        <input type="email" name="email" class="form-control" placeholder="Enter their email" required style="text-align: left;" />
                                        <small class="form-text text-muted">If they don’t have an account yet, they’ll be asked to sign up with this email.</small>
                                    </div>
                                    <button type="submit" class="btn btn-secondary btn-block" style="width: 100%;">
                                        <i class="fa-solid fa-envelope"></i> Send Invitation
                                    </button>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="statusActionModal" class="status-modal hidden">
                <div class="status-modal-backdrop"></div>
                <div class="status-modal-panel">
                    <div class="status-modal-header">
                        <h2 id="statusActionTitle">Send team response</h2>
                        <button type="button" id="statusActionClose" class="btn btn-ghost" aria-label="Close">×</button>
                    </div>
                    <p id="statusActionInfo" style="margin:0 0 18px; color:#475569;"></p>
                    <form id="statusActionForm" method="POST">
                        <input type="hidden" name="action" value="">
                        <div class="mb-3 status-custom-group">
                            <label class="form-label" for="statusCustomMessage">Custom response</label>
                            <textarea id="statusCustomMessage" name="customMessage" class="form-control" rows="5" placeholder="Add a custom message to the recipient..."></textarea>
                            <p class="small text-muted" style="margin-top:8px;">This message will be included in the email to the student.</p>
                        </div>
                        <div style="display:flex; justify-content:flex-end; gap: 12px; margin-top:18px;">
                            <button type="button" id="statusActionCancel" class="btn btn-secondary">Cancel</button>
                            <button type="submit" class="btn btn-primary">Send Email</button>
                        </div>
                    </form>
                </div>
            </div>

            <div id="recruitInfoModal" class="status-modal hidden">
                <div class="status-modal-backdrop"></div>
                <div class="status-modal-panel">
                    <div class="status-modal-header">
                        <h2 id="recruitInfoTitle">Applicant Info</h2>
                        <button type="button" id="recruitInfoClose" class="btn btn-ghost" aria-label="Close">×</button>
                    </div>
                    <dl class="recruit-info-grid">
                        <dt>Age</dt>
                        <dd id="recruitInfoAge"></dd>
                        <dt>Email</dt>
                        <dd id="recruitInfoEmail"></dd>
                        <dt>Phone</dt>
                        <dd id="recruitInfoPhone"></dd>
                        <dt>Interests</dt>
                        <dd id="recruitInfoInterests"></dd>
                        <dt>Background</dt>
                        <dd id="recruitInfoExperience"></dd>
                    </dl>
                </div>
            </div>

            <script>
                (function() {
                    const modal = document.getElementById('statusActionModal');
                    const form = document.getElementById('statusActionForm');
                    const actionTitle = document.getElementById('statusActionTitle');
                    const actionInfo = document.getElementById('statusActionInfo');
                    const messageGroup = document.querySelector('.status-custom-group');
                    const messageField = document.getElementById('statusCustomMessage');
                    const modalClose = document.getElementById('statusActionClose');
                    const modalCancel = document.getElementById('statusActionCancel');

                    function closeModal() {
                        modal.classList.add('hidden');
                        messageField.value = '';
                    }

                    function openModal(action, recruitId, recruitName) {
                        form.action = '/manage-team/recruit/' + recruitId + '/status';
                        form.querySelector('[name="action"]').value = action;
                        if (action === 'accept') {
                            actionTitle.textContent = 'Send Acceptance Email';
                            actionInfo.textContent = 'Add a custom message to help the student understand next steps.';
                            messageGroup.style.display = '';
                        } else if (action === 'waitlist') {
                            actionTitle.textContent = 'Send Waitlist Email';
                            actionInfo.textContent = 'Add a custom message to explain the waitlist process and next steps.';
                            messageGroup.style.display = '';
                        } else {
                            actionTitle.textContent = 'Send Rejection Email';
                            actionInfo.textContent = 'A confirmation will be required before the rejection email is sent.';
                            messageGroup.style.display = 'none';
                        }
                        modal.classList.remove('hidden');
                        messageField.focus();
                    }

                    document.querySelectorAll('.recruit-action-btn').forEach(button => {
                        button.addEventListener('click', function() {
                            const action = this.dataset.action;
                            const recruitId = this.dataset.recruitId;
                            const recruitName = this.dataset.recruitName;

                            if (action === 'reject') {
                                const confirmed = window.confirm('Send a rejection email to ' + recruitName + '? This cannot be undone.');
                                if (confirmed) {
                                    openModal(action, recruitId, recruitName);
                                    messageGroup.style.display = 'none';
                                }
                                return;
                            }

                            openModal(action, recruitId, recruitName);
                        });
                    });

                    modalCancel.addEventListener('click', closeModal);
                    modalClose.addEventListener('click', closeModal);

                    form.addEventListener('submit', function(event) {
                        const action = form.querySelector('[name="action"]').value;
                        const message = messageField.value.trim();
                        if (action === 'waitlist' || action === 'accept') {
                            if (!window.confirm('Send this email to the recruit now?')) {
                                event.preventDefault();
                                return;
                            }
                        }
                    });

                    const infoModal = document.getElementById('recruitInfoModal');
                    const infoClose = document.getElementById('recruitInfoClose');
                    const infoFields = {
                        title: document.getElementById('recruitInfoTitle'),
                        age: document.getElementById('recruitInfoAge'),
                        email: document.getElementById('recruitInfoEmail'),
                        phone: document.getElementById('recruitInfoPhone'),
                        interests: document.getElementById('recruitInfoInterests'),
                        experience: document.getElementById('recruitInfoExperience')
                    };

                    function fillInfoField(key, value) {
                        infoFields[key].textContent = value && value.trim() ? value : 'Not provided';
                    }

                    function closeInfoModal() {
                        infoModal.classList.add('hidden');
                    }

                    document.querySelectorAll('[data-recruit-info]').forEach(button => {
                        button.addEventListener('click', function() {
                            infoFields.title.textContent = this.dataset.name || 'Applicant Info';
                            fillInfoField('age', this.dataset.age || '');
                            fillInfoField('email', this.dataset.email || '');
                            fillInfoField('phone', this.dataset.phone || '');
                            fillInfoField('interests', this.dataset.interests || '');
                            fillInfoField('experience', this.dataset.experience || '');
                            infoModal.classList.remove('hidden');
                        });
                    });

                    infoClose.addEventListener('click', closeInfoModal);
                    infoModal.querySelector('.status-modal-backdrop').addEventListener('click', closeInfoModal);
                })();
            </script>

        <% } else { %>
            <div class="alert alert-info">
                You haven't registered a team yet. <a href="/team-register" class="alert-link">Register your team now</a> to start managing recruits.
            </div>
        <% } %>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const tabButtons = document.querySelectorAll('[data-settings-tab]');
            const tabPanels = document.querySelectorAll('[data-settings-panel]');
            const historyToggleButtons = document.querySelectorAll('.team-history-toggle');

            function activateTab(name) {
                document.querySelector('.settings-tabs')?.classList.toggle('is-admin', name === 'admin');
                tabButtons.forEach(function(button) {
                    const isActive = button.dataset.settingsTab === name;
                    button.classList.toggle('is-active', isActive);
                    button.setAttribute('aria-selected', isActive ? 'true' : 'false');
                });
                tabPanels.forEach(function(panel) {
                    panel.hidden = panel.dataset.settingsPanel !== name;
                });
            }

            tabButtons.forEach(function(button) {
                button.addEventListener('click', function() {
                    activateTab(this.dataset.settingsTab);
                });
            });

            activateTab('managers');

            historyToggleButtons.forEach(function(button) {
                button.addEventListener('click', function() {
                    const list = button.previousElementSibling;
                    if (!list || !list.classList.contains('team-history-list')) return;
                    const hiddenItems = list.querySelectorAll('[data-history-hidden="true"]');
                    const isExpanded = button.getAttribute('aria-expanded') === 'true';
                    const nextExpanded = !isExpanded;

                    hiddenItems.forEach(function(item) {
                        item.hidden = !nextExpanded;
                    });

                    button.setAttribute('aria-expanded', String(nextExpanded));
                    button.setAttribute('data-history-toggle', String(nextExpanded));

                    const icon = button.querySelector('.team-history-toggle-icon');
                    if (icon) {
                        icon.textContent = nextExpanded ? '↑' : '...';
                    }
                });
            });

            document.querySelectorAll('.manager-actions-dropdown').forEach(function(dropdown) {
                dropdown.addEventListener('toggle', function() {
                    var card = dropdown.closest('.manager-card');
                    if (!card) return;
                    if (dropdown.open) {
                        card.classList.add('manager-card-open');
                    } else {
                        card.classList.remove('manager-card-open');
                    }
                });
            });
        });
    </script>
    <script src="/assets/js/main.js"></script>
</body>
</html>
