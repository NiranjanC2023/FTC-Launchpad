<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Team | <%= team ? team.name : 'My Team' %></title>
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .dashboard-wrapper {
            width: min(100% - 28px, 1400px);
            padding: 34px 0 76px;
        }
        .page-header {
            margin-bottom: 28px;
            padding: 28px 30px;
            text-align: center !important;
            background: var(--surface);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            box-shadow: var(--shadow-sm);
        }
        .page-header h1 { font-size: 3.2rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 5px; }
        .page-header .subtitle { text-align: center; margin: 0; }
        .page-header .header-actions { display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 16px; }
        
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 18px; margin-bottom: 28px; }
        .stat-card { 
            background: var(--surface); border: 1px solid var(--border-color); border-radius: 10px;
            padding: 22px; display: flex; align-items: center; gap: 18px; box-shadow: var(--shadow-sm);
            transition: transform 0.2s ease;
        }
        .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
        .stat-icon { 
            width: 50px; height: 50px; border-radius: 10px; background: var(--accent-soft); 
            color: var(--accent-primary); display: grid; place-items: center; font-size: 1.4rem;
        }
        .stat-content h4 { margin: 0; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.5px; }
        .stat-content p { margin: 0; font-size: 1.3rem; font-weight: 800; color: var(--text-primary); }
        .stat-content .location-value { font-size: 1.05rem; line-height: 1.25; overflow-wrap: anywhere; }

        .dashboard-panel { 
            background: var(--surface); border: 1px solid var(--border-color); border-radius: 10px; 
            overflow: visible; box-shadow: var(--shadow-md); height: 100%;
        }
        .panel-head { 
            padding: 22px 24px; background: var(--surface-soft); border-bottom: 1px solid var(--border-color);
            display: flex; justify-content: space-between; align-items: center;
        }
        .panel-head h3 { margin: 0; font-size: 1.2rem; font-weight: 800; display: flex; align-items: center; gap: 10px; }
        .panel-body { padding: 24px; }
        .team-switcher {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .team-switcher .form-control {
            min-width: 260px;
        }
        .settings-tabs {
            position: relative;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            align-items: stretch;
            gap: 6px;
            padding: 6px;
            border: 1px solid var(--border-color);
            border-radius: 999px;
            background: var(--surface-soft);
            box-shadow: var(--shadow-sm);
            width: 100%;
            max-width: 520px;
            overflow: hidden;
        }
        .settings-tab-slider {
            position: absolute;
            top: 6px;
            left: 6px;
            width: calc(50% - 9px);
            height: calc(100% - 12px);
            border-radius: 999px;
            background: linear-gradient(135deg, #059669, #10b981);
            box-shadow: 0 10px 24px rgba(16, 185, 129, 0.22);
            transition: transform 0.24s ease;
            z-index: 0;
        }
        .settings-tabs.is-admin .settings-tab-slider {
            transform: translateX(calc(100% + 6px));
        }
        .settings-tab-button {
            appearance: none;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid transparent;
            background: transparent;
            color: var(--text-secondary);
            border-radius: 999px;
            padding: 0 18px;
            font-size: 0.9rem;
            font-weight: 800;
            line-height: 1;
            transition: background-color 0.18s ease, color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
            cursor: pointer;
            white-space: nowrap;
            width: 100%;
            min-height: 48px;
            text-align: center;
            margin: 0;
            position: relative;
            z-index: 1;
        }
        .settings-tab-button:hover {
            color: var(--text-primary);
            background: transparent;
            border-color: transparent;
            transform: translateY(-1px);
        }
        .settings-tab-button.is-active {
            color: #fff;
            border-color: transparent;
            box-shadow: none;
        }
        .settings-tab-button:focus-visible {
            outline: 2px solid var(--accent-primary);
            outline-offset: 2px;
        }
        .dashboard-columns {
            display: grid;
            grid-template-columns: minmax(0, 0.98fr) minmax(0, 1.42fr);
            gap: 20px;
            align-items: start;
        }
        .dashboard-sidebar,
        .dashboard-main {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }
        .dashboard-sidebar {
            position: static;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
            align-self: start;
        }
        .dashboard-sidebar > .dashboard-panel { margin: 0; }
        .dashboard-sidebar > .dashboard-panel:nth-of-type(1),
        .dashboard-sidebar > .dashboard-panel:nth-of-type(3),
        .dashboard-sidebar > .dashboard-panel:nth-of-type(6) {
            grid-column: 1 / -1;
        }
        .dashboard-sidebar > .dashboard-panel:nth-of-type(2),
        .dashboard-sidebar > .dashboard-panel:nth-of-type(4),
        .dashboard-sidebar > .dashboard-panel:nth-of-type(5) {
            align-self: start;
        }
        .dashboard-subpanel,
        .managers-box,
        .pending-box,
        .invite-box,
        .danger-box {
            padding: 14px;
            background: var(--surface);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            margin-bottom: 0;
        }
        .sidebar-card-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }
        .settings-form {
            grid-column: 1 / -1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            text-align: left;
        }
        .settings-form .mb-3 {
            margin-bottom: 0 !important;
            padding: 14px;
            background: var(--surface);
            border: 1px solid var(--border-color);
            border-radius: 10px;
        }
        .team-history-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
        }
        @media (max-width: 640px) {
            .settings-tabs {
                width: 100%;
                justify-content: stretch;
            }
            .settings-tab-button {
                flex: 1 1 100%;
                text-align: center;
                width: 100%;
            }
        }
        .history-box {
            padding: 12px;
            background: var(--bg-primary);
            border: 1px solid var(--border-color);
            border-radius: 10px;
        }
        .history-box strong {
            display: block;
            margin-bottom: 6px;
            color: var(--accent-primary);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .history-box p,
        .history-box ul {
            margin: 0;
            color: var(--text-primary);
        }
        .managers-box {
            grid-column: 1 / -1;
        }
        .dashboard-sidebar .dashboard-panel .panel-body {
            padding: 18px;
        }
        .pending-box,
        .invite-box,
        .danger-box {
            min-width: 0;
        }
        .managers-list {
            list-style: none;
            padding: 0;
            margin: 0 0 22px 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .recruit-card {
            background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: var(--radius-md);
            padding: 20px; margin-bottom: 15px; transition: all 0.2s ease; position: relative; overflow: hidden;
        }
        .recruit-card:hover { border-color: var(--accent-primary); transform: scale(1.01); background: var(--surface); }
        .recruit-card::after { 
            content: ''; position: absolute; left: 0; top: 0; height: 100%; width: 4px; 
            background: var(--accent-secondary); opacity: 0.6;
        }

        .btn-update { 
            background: var(--accent-primary); color: white; border: none; padding: 15px; 
            font-size: 1.1rem; border-radius: var(--radius-sm); font-weight: 800;
        }
        .btn-update:hover { background: #173d36; color: white; transform: translateY(-2px); }

        .status-pill { padding: 4px 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 900; background: #e0f2fe; color: #0369a1; }
        .recruit-action-row { display: flex; justify-content: flex-end; gap: 10px; flex-wrap: wrap; }
        .btn-rounded { border-radius: 9999px; }
        .btn-rounded.btn-sm { padding: 0.5rem 1rem; }
        .btn-rounded:disabled { opacity: 0.55; cursor: not-allowed; }
        .recruit-details-dropdown {
            margin-top: 12px;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            background: var(--surface);
            overflow: hidden;
        }
        .recruit-details-dropdown > summary {
            list-style: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 12px 14px;
            font-weight: 800;
            color: var(--text-primary);
        }
        .recruit-details-dropdown > summary::-webkit-details-marker { display: none; }
        .recruit-details-dropdown > summary::after {
            content: '\f078';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            color: var(--accent-primary);
            transition: transform 0.2s ease;
        }
        .recruit-details-dropdown[open] > summary::after {
            transform: rotate(180deg);
        }
        .recruit-details-panel {
            border-top: 1px solid var(--border-color);
            padding: 14px;
            background: var(--bg-primary);
        }
        .recruit-details-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }
        .recruit-detail-chip {
            padding: 10px 12px;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            background: var(--surface);
        }
        .recruit-detail-label {
            display: block;
            margin-bottom: 4px;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            font-weight: 800;
        }
        .recruit-detail-value {
            margin: 0;
            color: var(--text-primary);
            font-weight: 600;
            overflow-wrap: anywhere;
        }
        .recruit-detail-full { grid-column: 1 / -1; }
        .status-modal {
            position: fixed;
            inset: 0;
            z-index: 1000;
            display: grid;
            place-items: center;
            padding: 30px;
            overflow-y: auto;
        }
        .status-modal-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(15, 23, 42, 0.65);
            backdrop-filter: blur(2px);
        }
        .status-modal-panel {
            position: relative;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 30px 80px rgba(15,23,42,0.18);
            width: min(620px, 100%);
            max-height: none;
            overflow-y: visible;
            padding: 28px;
            z-index: 1;
        }
        .status-modal.hidden { display: none; }
        .status-modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
        .status-modal-header h2 { margin: 0; font-size: 1.4rem; }
        .btn-ghost { background: transparent; border: none; color: #475569; font-size: 1.5rem; line-height: 1; cursor: pointer; }
        .recruit-name-button {
            appearance: none;
            background: transparent;
            border: 0;
            color: var(--accent-primary);
            cursor: pointer;
            font: inherit;
            font-weight: 800;
            padding: 0;
            text-align: left;
        }
        .recruit-name-button:hover,
        .recruit-name-button:focus {
            text-decoration: underline;
        }
        .pending-invite-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .pending-invite-card {
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 16px 18px;
            background: var(--bg-primary);
        }
        .pending-invite-card strong {
            display: block;
            margin-bottom: 2px;
        }
        .pending-invite-meta {
            margin: 0;
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .recruit-info-grid {
            display: grid;
            grid-template-columns: 140px 1fr;
            gap: 12px 18px;
        }
        .recruit-info-grid dt {
            color: #64748b;
            font-weight: 800;
            margin: 0;
        }
        .recruit-info-grid dd {
            color: #0f172a;
            margin: 0;
            overflow-wrap: anywhere;
            white-space: pre-wrap;
        }
        @media (max-width: 640px) {
            .dashboard-wrapper {
                width: min(100% - 16px, 1400px);
            }
            .page-header {
                padding: 20px 18px;
            }
            .recruit-info-grid { grid-template-columns: 1fr; gap: 4px 0; }
            .recruit-info-grid dd { margin-bottom: 10px; }
        }
    </style>
</head>
<body class="dashboard-page">
    <header></header>
    <div class="container dashboard-wrapper">
        <% var team = typeof team !== 'undefined' ? team : null; %>
        <% var user = typeof user !== 'undefined' ? user : null; %>
        <% var teamManagers = Array.isArray(teamManagers) ? teamManagers : []; %>
        <% var pendingInvitations = Array.isArray(pendingInvitations) ? pendingInvitations : []; %>
        <% var recruits = Array.isArray(recruits) ? recruits : []; %>
        <% var waitlisted = Array.isArray(waitlisted) ? waitlisted : []; %>
        <% var acceptedRecruitList = Array.isArray(typeof acceptedRecruits !== 'undefined' ? acceptedRecruits : []) ? (typeof acceptedRecruits !== 'undefined' ? acceptedRecruits : []) : []; %>
        <% var teamOptions = Array.isArray(teamOptions) ? teamOptions : []; %>
        <% var teamSelectionOnly = typeof teamSelectionOnly !== 'undefined' ? teamSelectionOnly : false; %>
        <% var currentTeamRole = typeof currentTeamRole !== 'undefined' ? currentTeamRole : ''; %>
        <% var isCaptain = Boolean(currentTeamRole); %>
        <% const managedTeamOptions = Array.isArray(teamOptions) ? teamOptions : []; %>
        <div class="page-header">
            <h1>My Team</h1>
            <% if (team) { %>
                <p class="subtitle">Managing <strong><%= team.name %></strong> · Team #<%= team.teamNumber %></p>
            <% } else { %>
                <p class="subtitle">You are not currently managing a team.</p>
            <% } %>
            <div class="header-actions">
                <% if (managedTeamOptions.length > 1) { %>
                    <form class="team-switcher" method="get" action="/manage-team">
                        <label class="sr-only" for="teamSelector">Select a team</label>
                        <select id="teamSelector" name="team" class="form-control" onchange="this.form.submit()">
                            <% managedTeamOptions.forEach(function(option) { %>
                                <option value="<%= option._id %>" <%= team && String(team._id) === String(option._id) ? 'selected' : '' %>><%= option.name %> - <%= option.isNewTeam ? 'New Team' : ('Team #' + option.teamNumber) %></option>
                            <% }); %>
                        </select>
                    </form>
                <% } %>
                <a href="/teams-nearby" class="btn btn-secondary"><i class="fa-solid fa-earth-americas"></i> View Listing</a>
            </div>
        </div>
        
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-success" style="background: #d1fae5; color: #065f46; border-color: #a7f3d0;">
                <i class="fa-solid fa-circle-check"></i> <%= message %>
            </div>
        <% } %>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <% if (team) { %>
            <% const isPrimary = (user && user.email && team && team.contact && user.email.toLowerCase() === team.contact.toLowerCase()); %>
            <% const isManager = Boolean(currentTeamRole); %>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon" style="background: #fff7ed; color: #ea580c;"><i class="fa-solid fa-location-crosshairs"></i></div>
                    <div class="stat-content">
                        <h4>Base Location</h4>
                        <p class="location-value"><%= [team.city, team.state].filter(Boolean).join(', ') || team.country || 'Not set' %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #ecfeff; color: #0891b2;"><i class="fa-solid fa-hourglass-half"></i></div>
                    <div class="stat-content">
                        <h4>Time as a Team</h4>
                        <p><%= teamTenureLabel || 'Not available' %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-users-viewfinder"></i></div>
                    <div class="stat-content">
                        <h4>Total Recruits</h4>
                        <p><%= recruits ? recruits.length : 0 %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #fef3c7; color: #b45309;"><i class="fa-solid fa-star"></i></div>
                    <div class="stat-content">
                        <h4>Accepted</h4>
                        <p><%= typeof acceptedCount !== 'undefined' ? acceptedCount : 0 %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #ede9fe; color: #7c3aed;"><i class="fa-solid fa-hourglass-half"></i></div>
                    <div class="stat-content">
                        <h4>Waitlisted</h4>
                        <p><%= typeof waitlistCount !== 'undefined' ? waitlistCount : 0 %></p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #fee2e2; color: #b91c1c;"><i class="fa-solid fa-ban"></i></div>
                    <div class="stat-content">
                        <h4>Rejected</h4>
                        <p><%= typeof rejectedCount !== 'undefined' ? rejectedCount : 0 %></p>
                    </div>
                </div>
            </div>

            <div class="dashboard-columns">
                <div class="dashboard-sidebar">
                    <div class="dashboard-panel">
                        <div class="panel-head">
                            <h3><i class="fa-solid fa-trophy"></i> Team Snapshot</h3>
                        </div>
                        <div class="panel-body">
                            <form action="/manage-team/update" method="POST" class="text-left">
                                <div class="mb-3">
                                    <label class="form-label">Recruiting Bio</label>
                                    <textarea name="notes" class="form-control" rows="8" placeholder="Tell students about your team culture..."><%= team.notes %></textarea>
                                    <small class="text-muted">This bio appears on the public map.</small>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Awards Achieved</label>
                                    <div class="team-history-panel" style="margin: 0;">
                                        <% if (team.awardHistory && team.awardHistory.length) { %>
                                            <ul class="team-history-list" data-history-list="awards" style="margin: 0;">
                                                <% team.awardHistory.forEach(function(entry, index) { %>
                                                    <li class="team-history-item team-history-item--award" <%- index >= 2 ? 'hidden data-history-hidden="true"' : '' %>>
                                                        <span class="team-history-entry">
                                                            <span class="team-history-icon" aria-hidden="true"><i class="fa-solid fa-trophy"></i></span>
                                                            <span class="team-history-text"><%= entry %></span>
                                                            <span class="team-history-meta">Award</span>
                                                        </span>
                                                    </li>
                                                <% }) %>
                                            </ul>
                                            <% if (team.awardHistory.length > 2) { %>
                                                <button type="button" class="team-history-toggle" aria-expanded="false" aria-label="Show all awards achieved" data-history-toggle="false">
                                                    <span class="team-history-toggle-icon" aria-hidden="true">...</span>
                                                </button>
                                            <% } %>
                                        <% } else { %>
                                            No award history listed yet.
                                        <% } %>
                                    </div>
                                </div>
                                                                <div class="mb-3">
                                    <label class="form-label">Competition History</label>
                                    <div class="team-history-panel" style="margin: 0;">
                                        <% const visibleAdvancementHistory = Array.isArray(team.advancementHistory) ? team.advancementHistory.filter(function(item) { return !/qualif/i.test(String(item || '')); }) : []; %>
                                        <% if (visibleAdvancementHistory.length) { %>
                                            <ul class="team-history-list" data-history-list="advancement" style="margin: 0;">
                                                <% visibleAdvancementHistory.forEach(function(entry, index) { %>
                                                    <% const historyText = String(entry || '').trim(); %>
                                                    <% const historyClass = /world/i.test(historyText) ? 'team-history-item--worlds' : /regional/i.test(historyText) ? 'team-history-item--regional' : 'team-history-item--other'; %>
                                                    <li class="team-history-item <%= historyClass %>" <%- index >= 2 ? 'hidden data-history-hidden="true"' : '' %>>
                                                        <span class="team-history-entry">
                                                            <span class="team-history-icon" aria-hidden="true">
                                                                <i class="fa-solid <%= /world/i.test(historyText) ? 'fa-globe' : /regional/i.test(historyText) ? 'fa-flag' : 'fa-circle-dot' %>"></i>
                                                            </span>
                                                            <span class="team-history-text"><%= entry %></span>
                                                            <span class="team-history-meta"><%= /world/i.test(historyText) ? 'Worlds' : /regional/i.test(historyText) ? 'Regionals' : 'History' %></span>
                                                        </span>
                                                    </li>
                                                <% }) %>
                                            </ul>
                                            <% if (visibleAdvancementHistory.length > 2) { %>
                                                <button type="button" class="team-history-toggle" aria-expanded="false" aria-label="Show all competition history" data-history-toggle="false">
                                                    <span class="team-history-toggle-icon" aria-hidden="true">...</span>
                                                </button>
                                            <% } %>
                                        <% } else { %>
                                            No competition history listed yet.
                                        <% } %>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="checkbox-row" style="margin: 0; padding: 14px 15px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); cursor: pointer;">
                                        <input type="checkbox" name="recruiting" <%= team.recruiting ? 'checked' : '' %>>
                                        <span style="display:flex; flex-direction:column; gap:4px; font-weight: 800;">
                                            <span>Actively Recruiting</span>
                                            <span class="small text-muted" style="font-weight: 600;">Toggle visibility on the recruitment map.</span>
                                        </span>
                                    </label>
                                </div>
                                <button type="submit" class="btn btn-update btn-block">
                                    <i class="fa-solid fa-circle-check"></i> Save Changes
                                </button>
                            </form>

                            <hr style="border-top: 1px solid var(--border-color); margin: 30px 0;">
                            <div class="panel-body sidebar-managers-panel" style="padding: 0; display: none;">
                                <% function normalizeCaptainRoleManager(role) { const value = String(role || '').trim().toLowerCase(); return ['captain', 'outreach captain', 'technical captain'].includes(value) ? value : ''; } %>
                                <% function formatCaptainRoleManager(role) { const value = normalizeCaptainRoleManager(role); if (value === 'captain') return 'Captain'; if (value === 'outreach captain') return 'Outreach Captain'; if (value === 'technical captain') return 'Technical Captain'; return ''; } %>
                                <% const isPrimaryManager = (user && user.email && team && team.contact && user.email.toLowerCase() === team.contact.toLowerCase()); %>
