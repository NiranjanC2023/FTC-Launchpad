<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Team - FTC Starter Hub</title>
    <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
    <header></header>
    <div class="container">
        <div class="page-header">
            <h1>My Team</h1>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <% if (team) { %>
            <div class="jumbotron">
                <h2><%= team.name %></h2>
                <p class="lead">Team Number: <%= team.teamNumber %></p>
                <hr class="my-4">
                <p><strong>Location:</strong> <%= team.city %>, <%= team.state %>, <%= team.country %></p>
                <p><strong>Contact Info:</strong> <%= team.contact %></p>
                <p><strong>Years in Program:</strong> <%= team.yearsInProgram || 'Not listed yet.' %></p>
                <p><strong>Awards:</strong> <%= team.awards || 'No awards listed.' %></p>
                <p><strong>Advancement:</strong> <%= team.advancementLevels && team.advancementLevels.length ? team.advancementLevels.join(', ') : 'No advancement listed.' %></p>
                <p><strong>Awards Achieved:</strong></p>
                <% if (team.awardHistory && team.awardHistory.length) { %>
                    <ul>
                        <% team.awardHistory.forEach(function(entry) { %>
                            <li>🏅 <%= entry %></li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p>No award history listed.</p>
                <% } %>
                <p><strong>Advancement History:</strong></p>
                <% if (team.advancementHistory && team.advancementHistory.length) { %>
                    <ul>
                        <% team.advancementHistory.forEach(function(entry) { %>
                            <li>🏁 <%= entry %></li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p>No advancement history listed.</p>
                <% } %>
                <p><strong>Notes:</strong> <%= team.notes || 'No notes available.' %></p>
            </div>
        <% } else { %>
            <div class="alert alert-warning">
                We couldn't find team information for team #<%= user.teamNumber %>. 
                Please check with your team lead to ensure the team is registered.
            </div>
        <% } %>
    </div>
    <script src="/assets/js/main.js"></script>
</body>
</html>
