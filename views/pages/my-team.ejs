<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Team - FTC Starter Hub</title>
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .my-team-hero {
            margin-bottom: 18px;
            padding: 26px 28px;
            background: linear-gradient(180deg, rgba(16, 185, 129, 0.08), rgba(255, 255, 255, 0.98));
            border: 1px solid rgba(16, 185, 129, 0.22);
            border-radius: 18px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
        }
        .my-team-hero-top {
            display: flex;
            flex-wrap: wrap;
            gap: 18px;
            align-items: flex-start;
            justify-content: space-between;
        }
        .my-team-hero h1 {
            margin: 0 0 6px;
            font-size: clamp(2rem, 4vw, 3rem);
            line-height: 1;
            font-weight: 900;
            letter-spacing: -0.04em;
        }
        .my-team-hero .hero-subtitle {
            margin: 0;
            color: var(--text-secondary);
            font-size: 0.98rem;
        }
        .my-team-hero .hero-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 14px;
        }
        .my-team-hero .meta-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 9px 12px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(16, 185, 129, 0.18);
            color: var(--text-primary);
            font-size: 0.88rem;
            font-weight: 700;
        }
        .my-team-chooser {
            display: flex;
            flex-direction: column;
            gap: 10px;
            min-width: min(100%, 340px);
            padding: 16px;
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(16, 185, 129, 0.18);
            border-radius: 16px;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.06);
        }
        .my-team-chooser .chooser-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.78rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
        }
        .my-team-chooser form {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
            margin: 0;
        }
        .my-team-chooser select.form-control {
            min-width: 240px;
            flex: 1 1 240px;
            min-height: 46px;
            border-radius: 12px;
            border-color: rgba(15, 118, 110, 0.22);
            box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.04);
        }
        .my-team-chooser .btn {
            min-height: 46px;
            padding-inline: 18px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            white-space: nowrap;
        }
        @media (max-width: 720px) {
            .my-team-hero {
                padding: 20px;
            }
            .my-team-chooser {
                width: 100%;
            }
            .my-team-chooser select.form-control,
            .my-team-chooser .btn {
                width: 100%;
                flex: 1 1 100%;
            }
        }
    </style>
</head>
<body>
    <header></header>
    <div class="container">
        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <% const availableTeamOptions = Array.isArray(typeof teamOptions !== 'undefined' ? teamOptions : []) ? (typeof teamOptions !== 'undefined' ? teamOptions : []) : []; %>
        <% const isTeamSelectionOnly = typeof teamSelectionOnly !== 'undefined' ? teamSelectionOnly : false; %>
        <% const currentTeamTenureLabel = typeof teamTenureLabel !== 'undefined' ? teamTenureLabel : null; %>

        <div class="my-team-hero">
            <div class="my-team-hero-top">
                <div>
                    <h1>My Team</h1>
                    <% if (team) { %>
                        <p class="hero-subtitle">Managing <strong><%= team.name %></strong><%= team.teamNumber ? (' · Team #' + team.teamNumber) : '' %></p>
                    <% } else if (isTeamSelectionOnly) { %>
                        <p class="hero-subtitle">You manage more than one team. Pick the one you want to open.</p>
                    <% } else { %>
                        <p class="hero-subtitle">View your team profile and jump into the command area when you're ready.</p>
                    <% } %>
                    <% if (team) { %>
                        <div class="hero-meta">
                            <span class="meta-pill"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> <%= [team.city, team.state].filter(Boolean).join(', ') || team.country || 'Location not listed' %></span>
                            <span class="meta-pill"><i class="fa-solid fa-users" aria-hidden="true"></i> <%= team.recruiting ? 'Recruiting' : 'Not recruiting' %></span>
                            <span class="meta-pill"><i class="fa-solid fa-calendar-days" aria-hidden="true"></i> <%= currentTeamTenureLabel || 'Tenure not available' %></span>
                        </div>
                    <% } %>
                </div>

                <% if (availableTeamOptions.length > 1) { %>
                    <div class="my-team-chooser">
                        <span class="chooser-label"><i class="fa-solid fa-layer-group" aria-hidden="true"></i> Select Team</span>
                        <form method="get" action="/manage-team">
                            <select name="team" class="form-control" required>
                                <option value="">Select a team</option>
                                <% availableTeamOptions.forEach(function(option) { %>
                                    <option value="<%= option._id %>" <%= team && String(team._id) === String(option._id) ? 'selected' : '' %>>
                                        <%= option.name %> - <%= option.isNewTeam ? 'New Team' : ('Team #' + option.teamNumber) %>
                                    </option>
                                <% }); %>
                            </select>
                            <button type="submit" class="btn btn-primary">Team Settings</button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>

        <% if (team) { %>
            <div class="jumbotron">
                <div style="display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap; align-items:center;">
                    <div>
                        <h2 style="margin-bottom: 6px;"><%= team.name %></h2>
                        <p class="lead" style="margin-bottom: 0;">Team Number: <%= team.teamNumber %></p>
                    </div>
                    <a class="btn btn-secondary" href="/manage-team?team=<%= team._id %>">
                        <i class="fa-solid fa-gear"></i> Open Team Settings
                    </a>
                </div>
                <hr class="my-4">
                <p><strong>Location:</strong> <%= team.city %>, <%= team.state %>, <%= team.country %></p>
                <p><strong>Contact Info:</strong> <%= team.contact %></p>
                <p><strong>Years in Program:</strong> <%= team.yearsInProgram || 'Not listed yet.' %></p>
                <p><strong>FTC Region:</strong> <%= team.competitionRegionLabel || 'Region not available.' %></p>
                <p><strong>Awards:</strong> <%= team.awards || 'No awards listed.' %></p>
                <% const advancementLevels = Array.isArray(team.advancementLevels) ? team.advancementLevels.filter(function(level) { return level === 'Regional' || level === 'Worlds'; }) : []; %>
                <% const advancementHistory = Array.isArray(team.advancementHistory) ? team.advancementHistory.filter(function(entry) { return /^(Regional|Worlds)\b/i.test(String(entry || '').trim()); }) : []; %>
                <p><strong>Advancement:</strong> <%= advancementLevels.length ? advancementLevels.join(', ') : 'No advancement listed.' %></p>
                <p><strong>Awards Achieved:</strong></p>
                <% if (team.awardHistory && team.awardHistory.length) { %>
                    <ul>
                        <% team.awardHistory.forEach(function(entry) { %>
                            <li><i class="fa-solid fa-trophy"></i> <%= entry %></li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p>No award history listed.</p>
                <% } %>
                <p><strong>Advancement History:</strong></p>
                <% if (advancementHistory.length) { %>
                    <ul>
                        <% team.advancementHistory.forEach(function(entry) { %>
                            <li><i class="fa-solid fa-flag"></i> <%= entry %></li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p>No advancement history listed.</p>
                <% } %>
                <p><strong>Notes:</strong> <%= team.notes || 'No notes available.' %></p>
            </div>
        <% } else if (isTeamSelectionOnly) { %>
            <div class="alert alert-info">
                You manage more than one team. Use the selector above to open the team you want to view.
            </div>
        <% } else { %>
            <% const userTeamNumber = user && user.teamNumber ? user.teamNumber : null; %>
            <div class="alert alert-warning">
                We couldn't find team information for <%= userTeamNumber ? ('team #' + userTeamNumber) : 'your account' %>.
                Please check with your team lead to ensure the team is registered.
            </div>
        <% } %>
    </div>
    <script src="/assets/js/main.js"></script>
</body>
</html>
