<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Sign Up — Team Manager</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
</head>
<body class="auth-page">
  <header></header>

  <main>
    <div class="container">
      <a href="<%= nextPath ? '/auth-gate?next=' + encodeURIComponent(nextPath) : '/signup' %>" class="btn btn-secondary back-button">← Back</a>
      <h1>Sign Up — Managing a Team</h1>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form id="signupForm" method="POST" action="/signup">
        <input type="hidden" name="signupMode" value="manager" />
        <input type="hidden" name="inviteToken" value="<%= inviteToken || '' %>" />
        <input type="hidden" name="next" value="<%= nextPath || '' %>" />

        <div class="mb-3">
          <label class="form-label">Full name</label>
          <input name="name" id="name" class="form-control" value="<%= values && values.name ? values.name : '' %>" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input name="email" id="email" type="email" class="form-control" value="<%= values && values.email ? values.email : '' %>" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input name="password" id="password" type="password" class="form-control" required />
        </div>

        <p class="text-muted" style="margin: 0 0 18px;">You can connect to a team after sign up from your dashboard.</p>

        <button class="btn btn-primary" type="submit">Create account</button>
      </form>

      <p style="margin-top:14px">Already have an account? <a href="/login<%= nextPath ? '?next=' + encodeURIComponent(nextPath) : '' %>">Log in</a></p>
    </div>
  </main>

  <script src="/assets/js/main.js?v=37"></script>
</body>
</html>
