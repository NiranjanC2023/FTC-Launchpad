<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Sign Up to Join - FTC Starter Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Google Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/main.css?v=13">
</head>
<body>
  <header></header>

  <main>
    <div class="container">
      <a href="/" class="btn btn-secondary back-button">← Back Home</a>

      <h1>Sign Up to Join a Team</h1>
      <p class="subtitle">Enter your details and we'll show nearby teams you can contact.</p>

      <form id="joinForm" class="form-grid">
        <label for="name">Full name</label>
        <input id="name" name="name" required>

        <label for="age">Age</label>
        <input id="age" name="age" type="number" min="8" max="120">

        <label for="experience">Experience (brief)</label>
        <input id="experience" name="experience" placeholder="e.g., none, some Java, built RC car">

        <label for="interests">Interests / Roles</label>
        <input id="interests" name="interests" placeholder="programming, mechanical, outreach">

        <label for="email">Email</label>
        <input id="email" name="email" type="email">

        <label for="phone">Phone (optional)</label>
        <input id="phone" name="phone" type="tel">

        <div></div>
        <div>
          <button type="submit" class="btn btn-primary">Find Teams Near Me</button>
        </div>
      </form>
    </div>
  </main>

  <script src="/assets/js/main.js?v=8"></script>
</body>
</html>
